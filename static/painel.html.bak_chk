<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Hub Tecnico — Painel</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
:root{
  --bg:#0f1117;--surf:#161b22;--surf2:#1c2330;--surf3:#21283a;
  --border:#2d3748;--border2:#374151;
  --text:#e2e8f0;--text2:#94a3b8;--text3:#64748b;
  --accent:#e8521a;--accent2:#ff6b35;
  --green:#00e5a0;--red:#ff4d6a;--amber:#ffb83f;--blue:#60a5fa;--purple:#a78bfa;
  --radius:10px;--font:'Inter',system-ui,sans-serif;
  --sb-w:220px;--tb-h:52px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-font-smoothing:antialiased}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px;overflow:hidden}
#shell{display:flex;height:100vh}
#sidebar{width:var(--sb-w);background:var(--surf);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;transition:width .25s;overflow:hidden;z-index:50}
#sidebar.collapsed{width:52px}
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
#topbar{height:var(--tb-h);background:var(--surf);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:8px;flex-shrink:0;flex-wrap:nowrap;overflow-x:auto}
#content{flex:1;overflow:hidden;position:relative}
.sb-head{padding:0 12px;height:var(--tb-h);display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);flex-shrink:0}
.sb-logo{display:flex;align-items:center;gap:8px;flex:1;min-width:0}
.sb-logo-icon{width:28px;height:28px;border-radius:7px;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.9rem}
.sb-logo-text{font-size:14px;font-weight:800;letter-spacing:-.3px;white-space:nowrap;overflow:hidden}
.sb-logo-text span{color:var(--accent)}
.sb-toggle{background:none;border:none;color:var(--text3);cursor:pointer;padding:5px;border-radius:5px;display:flex;flex-shrink:0}
.sb-toggle:hover{background:var(--surf2);color:var(--text)}
.sb-nav{flex:1;overflow-y:auto;padding:8px 6px}
.sb-nav::-webkit-scrollbar{display:none}
.sb-group{font-size:10px;font-weight:600;letter-spacing:.08em;color:var(--text3);padding:10px 8px 4px;text-transform:uppercase;white-space:nowrap;overflow:hidden}
#sidebar.collapsed .sb-group{visibility:hidden}
.ni{display:flex;align-items:center;gap:9px;padding:7px 8px;border-radius:7px;cursor:pointer;transition:all .15s;position:relative;white-space:nowrap}
.ni:hover{background:var(--surf2)}
.ni.active{background:rgba(232,82,26,.15);color:var(--accent)}
.ni svg{width:16px;height:16px;flex-shrink:0;color:var(--text3)}
.ni.active svg{color:var(--accent)}
.ni-label{font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis}
#sidebar.collapsed .ni-label{display:none}
.sb-user{padding:12px;border-top:1px solid var(--border);flex-shrink:0}
.sb-user-info{display:flex;align-items:center;gap:8px}
.sb-avatar{width:30px;height:30px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.8rem;color:#fff;flex-shrink:0}
.sb-uname{font-size:.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-urole{font-size:.72rem;color:var(--text3)}
#sidebar.collapsed .sb-user-info > *:not(.sb-avatar){display:none}
.tb-title{font-weight:800;font-size:.95rem;flex-shrink:0}
.stat-pill{display:flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;font-size:.75rem;font-weight:700;border:1px solid var(--border);cursor:pointer;transition:all .15s;flex-shrink:0;white-space:nowrap}
.stat-pill:hover{opacity:.8}
.stat-pill.active{border-color:currentColor;background:rgba(255,255,255,.04)}
.stat-pill:not(.active){opacity:.45}
.btn{padding:6px 12px;border-radius:7px;border:none;cursor:pointer;font-weight:600;font-size:.8rem}
.btn-p{background:var(--accent);color:#fff}
.btn-o{background:transparent;border:1px solid var(--border);color:var(--text)}
.btn-o:hover{border-color:var(--accent);color:var(--accent)}
.secao{display:none;height:100%;overflow:hidden}
.secao.ativa{display:flex;flex-direction:column}
#mapa{flex:1;z-index:1}

/* SIDEBAR OS */
#sidebar-os{width:290px;background:var(--surf);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
.os-stats-bar{padding:10px 12px;border-bottom:1px solid var(--border);flex-shrink:0}
.os-stats-title{font-size:.78rem;font-weight:700;color:var(--text3);margin-bottom:6px}
.os-stats-row{display:flex;gap:6px;flex-wrap:wrap}
.os-stat-chip{display:flex;align-items:center;gap:4px;font-size:.72rem;font-weight:700;padding:3px 8px;border-radius:12px;border:1px solid var(--border);background:var(--surf2)}
.os-lista{flex:1;overflow-y:auto;padding:8px}
.os-lista::-webkit-scrollbar{width:3px}
.os-lista::-webkit-scrollbar-thumb{background:var(--border2)}
.os-item{padding:10px 12px;border-radius:8px;border:1px solid var(--border);margin-bottom:6px;cursor:pointer;transition:all .15s}
.os-item:hover{border-color:var(--accent);background:var(--surf2)}
.os-item.selected{border-color:var(--accent);background:rgba(232,82,26,.08)}
.os-item-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px}
.os-num{font-size:.7rem;color:var(--text3)}
.os-badge{font-size:.65rem;font-weight:700;padding:2px 6px;border-radius:10px}
.badge-pendente{background:rgba(255,77,106,.15);color:var(--red)}
.badge-deslocamento{background:rgba(255,184,63,.15);color:var(--amber)}
.badge-agendada{background:rgba(167,139,250,.15);color:var(--purple)}
.badge-reagendada{background:rgba(167,139,250,.15);color:var(--purple)}
.badge-execucao{background:rgba(96,165,250,.15);color:var(--blue)}
.badge-finalizada{background:rgba(0,229,160,.15);color:var(--green)}
.os-cliente{font-weight:700;font-size:.85rem;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.os-end{font-size:.73rem;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.os-meta{display:flex;justify-content:space-between;margin-top:5px;font-size:.7rem;color:var(--text3)}

/* MODAL OS DETALHE */
#modal-detalhe{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:999;align-items:center;justify-content:center}
#modal-detalhe.open{display:flex}
.modal{background:var(--surf);border:1px solid var(--border);border-radius:14px;padding:24px;width:100%;max-width:480px;max-height:90vh;overflow-y:auto}
.modal-title{font-size:1rem;font-weight:800;margin-bottom:18px;display:flex;justify-content:space-between;align-items:center}
.modal-close{background:none;border:none;color:var(--text3);cursor:pointer;font-size:1.1rem;padding:0 4px}
.modal-close:hover{color:var(--text)}
.detalhe-row{display:flex;gap:8px;margin-bottom:8px}
.detalhe-label{font-size:.7rem;color:var(--text3);font-weight:700;text-transform:uppercase;min-width:90px;flex-shrink:0;padding-top:2px}
.detalhe-val{font-size:.85rem;color:var(--text);font-weight:500}
.detalhe-divider{border:none;border-top:1px solid var(--border);margin:12px 0}

/* MODAL ATRIBUIR */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.field{margin-bottom:12px}
.field label{display:block;font-size:.73rem;color:var(--text3);font-weight:700;text-transform:uppercase;margin-bottom:5px}
.field input,.field select{width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;font-size:.88rem;outline:none}
.field input:focus,.field select:focus{border-color:var(--accent)}
.tecnico-option{display:flex;align-items:center;justify-content:space-between;padding:10px 12px;border-radius:8px;border:1px solid var(--border);margin-bottom:6px;cursor:pointer;transition:all .15s}
.tecnico-option:hover{border-color:var(--accent)}
.tecnico-option.best{border-color:var(--amber)}

/* TECNICOS NO MAPA — legenda */
.legenda-mapa{position:absolute;bottom:20px;right:10px;z-index:500;background:var(--surf);border:1px solid var(--border);border-radius:10px;padding:10px 14px;font-size:.75rem;min-width:160px}
.legenda-mapa b{display:block;margin-bottom:6px;font-size:.72rem;color:var(--text3);text-transform:uppercase}
.legenda-item{display:flex;align-items:center;gap:7px;margin-bottom:4px}
.legenda-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0}

/* CARDS DIA — bottom bar */
#cards-dia{position:absolute;bottom:0;left:290px;right:0;z-index:400;background:rgba(22,27,34,.95);border-top:1px solid var(--border);display:flex;gap:0;height:52px}
.card-dia{flex:1;display:flex;align-items:center;justify-content:center;gap:8px;border-right:1px solid var(--border);padding:0 12px;cursor:default}
.card-dia:last-child{border-right:none}
.card-dia-num{font-size:1.2rem;font-weight:900}
.card-dia-label{font-size:.68rem;color:var(--text3);font-weight:600;text-transform:uppercase;line-height:1.3}

/* SECAO USUARIOS */
#secao-usuarios{padding:20px;overflow-y:auto}
table{width:100%;border-collapse:collapse}
th{text-align:left;font-size:.72rem;color:var(--text3);font-weight:700;text-transform:uppercase;padding:8px 12px;border-bottom:1px solid var(--border)}
td{padding:9px 12px;border-bottom:1px solid rgba(45,55,72,.5);font-size:.85rem}

/* LOGIN */
#P-LOGIN{min-height:100vh}

/* TOAST */
.toast{position:fixed;bottom:70px;left:50%;transform:translateX(-50%);background:var(--surf3);border:1px solid var(--border);border-radius:8px;padding:10px 20px;font-size:.85rem;font-weight:600;z-index:9999;transition:opacity .3s;pointer-events:none}
.toast.ok{border-color:var(--green);color:var(--green)}
.toast.err{border-color:var(--red);color:var(--red)}

/* TECNICO PARADO indicator */
.tec-parado-vermelho{background:#ff4d6a!important}
.tec-parado-laranja{background:#ffb83f!important}

    /* REVISOES */
    .rev-stat-card {
      background: var(--surf);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 10px 16px;
      min-width: 110px;
      text-align: center;
    }
    .rsc-num { font-size: 1.6rem; font-weight: 900; line-height: 1; }
    .rsc-label { font-size: .7rem; color: var(--text3); margin-top: 3px; font-weight: 600; }
    .rev-card {
      background: var(--surf);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 10px;
      border-left: 4px solid var(--border);
      transition: box-shadow .2s;
    }
    .rev-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.2); }
    .rev-card.vencido  { border-left-color: #ef4444; background: rgba(239,68,68,.04); }
    .rev-card.urgente  { border-left-color: #f59e0b; background: rgba(245,158,11,.04); }
    .rev-card.aviso    { border-left-color: #3b82f6; background: rgba(59,130,246,.04); }
    .rev-card.ok       { border-left-color: #22c55e; }
    .rev-grupo-titulo {
      font-size: .72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--text3);
      padding: 6px 0 8px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 10px;
      margin-top: 4px;
    }
  
    .chip-item {
      display:inline-block;
      padding:4px 10px;
      background:var(--surf2);
      border:1.5px solid var(--border);
      border-radius:20px;
      font-size:.75rem;
      cursor:pointer;
      transition:all .15s;
      user-select:none;
      color:var(--text);
    }
    .chip-item:hover { border-color:var(--accent); color:var(--accent); }
    .chip-item.selecionado { background:var(--accent); border-color:var(--accent); color:#fff; font-weight:700; }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="P-LOGIN" style="display:none;position:fixed;inset:0;z-index:9999;background:var(--bg)">
  <div style="display:flex;height:100vh;width:100vw">
    <div style="flex:1;background:linear-gradient(135deg,#0d0f14 60%,#1c2230);display:flex;flex-direction:column;justify-content:center;padding:60px;overflow-y:auto">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:40px">
        <div style="width:40px;height:40px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center">🔧</div>
        <span style="font-weight:800;font-size:1.2rem">Hub<span style="color:var(--accent)">Tecnico</span></span>
      </div>
      <h1 style="font-size:2rem;font-weight:900;line-height:1.2;margin-bottom:12px">Controle de OS<br><span style="color:var(--accent)">e Frota</span></h1>
      <p style="color:var(--text3);font-size:.9rem;max-width:360px;line-height:1.6;margin-bottom:32px">Gerencie ordens de servico, rotas de tecnicos e frota de veiculos em tempo real.</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;max-width:380px">
        <div style="background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:10px"><div style="font-size:.82rem;font-weight:700">📋 Hub Comercial</div><div style="font-size:.7rem;color:var(--text3)">Vendas e ativacao</div><span style="font-size:.65rem;background:rgba(34,229,160,.15);color:var(--green);padding:2px 6px;border-radius:4px;margin-top:4px;display:inline-block">Ativo</span></div>
        <div style="background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:10px"><div style="font-size:.82rem;font-weight:700">💰 Hub Cobranca</div><div style="font-size:.7rem;color:var(--text3)">Gestao financeira</div><span style="font-size:.65rem;background:rgba(34,229,160,.15);color:var(--green);padding:2px 6px;border-radius:4px;margin-top:4px;display:inline-block">Ativo</span></div>
        <div style="background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:10px"><div style="font-size:.82rem;font-weight:700">📊 Hub Produtividade</div><div style="font-size:.7rem;color:var(--text3)">Ranking e SLA</div><span style="font-size:.65rem;background:rgba(34,229,160,.15);color:var(--green);padding:2px 6px;border-radius:4px;margin-top:4px;display:inline-block">Ativo</span></div>
        <div style="background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:10px;padding:10px"><div style="font-size:.82rem;font-weight:700">🔧 Hub Tecnico</div><div style="font-size:.7rem;color:var(--text3)">OS e frota</div><span style="font-size:.65rem;background:rgba(232,82,26,.15);color:var(--accent);padding:2px 6px;border-radius:4px;margin-top:4px;display:inline-block">Beta</span></div>
      </div>
    </div>
    <div style="width:420px;min-width:420px;background:var(--surf);border-left:1px solid var(--border);display:flex;flex-direction:column;justify-content:center;padding:48px">
      <div style="font-size:1.3rem;font-weight:900;margin-bottom:6px">Bem-vindo</div>
      <div style="color:var(--text3);font-size:.85rem;margin-bottom:28px">Faca login para continuar.</div>
      <div style="margin-bottom:14px"><label style="font-size:.73rem;color:var(--text3);font-weight:700;text-transform:uppercase">Login</label><input type="text" id="inp-login" placeholder="seu.login" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:9px 12px;font-size:.88rem;outline:none;margin-top:5px"></div>
      <div style="margin-bottom:14px"><label style="font-size:.73rem;color:var(--text3);font-weight:700;text-transform:uppercase">Senha</label><input type="password" id="inp-senha" placeholder="senha" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:9px 12px;font-size:.88rem;outline:none;margin-top:5px"></div>
      <div id="login-err" style="color:var(--red);font-size:.82rem;margin-bottom:10px;display:none"></div>
      <button onclick="fazerLogin()" style="width:100%;padding:12px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-weight:700;font-size:.95rem;cursor:pointer">Entrar</button>
      <div style="text-align:center;font-size:.72rem;color:var(--text3);margin-top:20px">Hub Tecnico v1.1 - IaTechHub 2026</div>
    </div>
  </div>
</div>

<!-- APP -->
<div id="P-APP" style="display:none;height:100vh">
<div id="shell">

  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="sb-head">
      <div class="sb-logo">
        <div class="sb-logo-icon">🔧</div>
        <div class="sb-logo-text">Hub<span>Tecnico</span></div>
      </div>
      <button class="sb-toggle" onclick="toggleSidebar()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
    <nav class="sb-nav">
      <div class="sb-group" id="grp-os" style="display:none">ORDENS DE SERVICO</div>
      <div class="ni" id="ni-os" style="display:none" onclick="navTo('os')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        <span class="ni-label">Controle de OS</span>
      </div>
      <div class="sb-group" id="grp-frota" style="display:none">FROTA</div>
      <div class="ni" id="ni-frota" style="display:none" onclick="navTo('frota')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <span class="ni-label">Frota</span>
      </div>
      <div class="ni" id="ni-revisoes" style="display:none" onclick="navTo('revisoes')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        <span class="ni-label">Revisões</span>
      </div>
      <div class="ni" id="ni-despesas" style="display:none" onclick="navTo('despesas')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        <span class="ni-label">Despesas</span>
      </div>
      <div class="ni" id="ni-custos" style="display:none" onclick="navTo('custos')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        <span class="ni-label">Custos</span>
      </div>
      <div class="ni" id="ni-checklists" style="display:none" onclick="navTo('checklists')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        <span class="ni-label">Checklists</span>
      </div>
      <div class="ni" id="ni-abastecimentos" style="display:none" onclick="navTo('abastecimentos')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 22V10l9-8 9 8v12H3z"/><path d="M9 22v-6h6v6"/><path d="M12 2v4m0 0a2 2 0 110 4 2 2 0 010-4z"/></svg>
        <span class="ni-label">Abastecimentos</span>
      </div>
      <div class="sb-group" id="grp-admin" style="display:none">ADMINISTRACAO</div>
      <div class="ni" id="ni-usuarios" style="display:none" onclick="navTo('usuarios')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        <span class="ni-label">Usuarios</span>
      </div>
    </nav>
    <div class="sb-user">
      <div class="sb-user-info">
        <div class="sb-avatar" id="sb-avatar">A</div>
        <div>
          <div class="sb-uname" id="sb-nome">—</div>
          <div class="sb-urole" id="sb-role">—</div>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div id="main">
    <!-- TOPBAR -->
    <div id="topbar">
      <div class="tb-title" id="tb-titulo">Controle de OS</div>
      <div id="tb-stats-os" style="display:flex;align-items:center;gap:6px;flex-wrap:nowrap">
        <div class="stat-pill active" style="color:var(--red)" id="f-pendente" onclick="toggleFiltro('pendente',this)">🔴 Pendentes <b id="cnt-pendente">0</b></div>
        <div class="stat-pill active" style="color:var(--amber)" id="f-deslocamento" onclick="toggleFiltro('deslocamento',this)">🟡 Deslocamento <b id="cnt-deslocamento">0</b></div>
        <div class="stat-pill active" style="color:var(--purple)" id="f-agendada" onclick="toggleFiltro('agendada',this)">📅 Agendada <b id="cnt-agendada">0</b></div>
        <div class="stat-pill active" style="color:var(--blue)" id="f-execucao" onclick="toggleFiltro('execucao',this)">🔵 Execucao <b id="cnt-execucao">0</b></div>
        <div style="width:1px;background:var(--border);height:20px;flex-shrink:0"></div>
        <select id="sel-tipo" onchange="selecionarTipo(this.value)" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none;flex-shrink:0">
          <option value="todos">Todos os tipos</option>
          <option value="suporte">Suporte</option>
          <option value="instalacao">Servico</option>
          <option value="infra">Infra</option>
          <option value="retirada">Retirada</option>
        </select>
        <input type="date" id="filtro-data-ini" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none;flex-shrink:0" onchange="renderSidebar();renderMapa()">
        <span style="color:var(--text3);font-size:.75rem;flex-shrink:0">até</span>
        <input type="date" id="filtro-data-fim" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none;flex-shrink:0" onchange="renderSidebar();renderMapa()">
        <button class="btn btn-o" style="padding:4px 8px;font-size:.75rem;flex-shrink:0" onclick="limparDatas()">✕</button>
      </div>
      <div style="margin-left:auto;display:flex;gap:6px;flex-shrink:0">
        <button class="btn btn-o" onclick="carregarDados()">↻</button>
        <button class="btn btn-o" onclick="logout()">Sair</button>
      </div>
    </div>

    <!-- CONTEUDO -->
    <div id="content">

      <!-- SECAO OS -->
      <div class="secao ativa" id="secao-os" style="flex-direction:row">

        <!-- SIDEBAR OS: lista lateral -->
        <div id="sidebar-os">
          <div class="os-stats-bar">
            <div class="os-stats-title">OS DO DIA — <span id="st-total">0</span> total</div>
            <div class="os-stats-row">
              <div class="os-stat-chip" style="color:var(--red)">🔴 <span id="st-pendente">0</span></div>
              <div class="os-stat-chip" style="color:var(--amber)">🟡 <span id="st-deslocamento">0</span></div>
              <div class="os-stat-chip" style="color:var(--purple)">📅 <span id="st-agendada">0</span></div>
              <div class="os-stat-chip" style="color:var(--blue)">🔵 <span id="st-execucao">0</span></div>
              <div class="os-stat-chip" style="color:var(--green)">✅ <span id="st-finalizada">0</span></div>
              <div class="os-stat-chip" style="color:var(--text2)">🚗 <span id="st-tecnicos">0</span></div>
            </div>
          </div>
          <div class="os-lista" id="lista-os"></div>
        </div>

        <!-- MAPA -->
        <div style="flex:1;position:relative;display:flex;flex-direction:column">
          <div id="mapa" style="flex:1;padding-bottom:52px"></div>

          <!-- LEGENDA -->
          <div class="legenda-mapa" style="bottom:62px">
            <b>Tecnicos</b>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--green)"></div>Em movimento</div>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--amber)"></div>Parado</div>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--red)"></div>Parado +30min</div>
            <b style="margin-top:8px">OS</b>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--red)"></div>Pendente</div>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--amber)"></div>Deslocamento</div>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--purple)"></div>Agendada</div>
            <div class="legenda-item"><div class="legenda-dot" style="background:var(--blue)"></div>Execucao</div>
          </div>

          <!-- CARDS DIA -->
          <div id="cards-dia">
            <div class="card-dia">
              <div class="card-dia-num" style="color:var(--text)"><span id="cd-total">0</span></div>
              <div class="card-dia-label">Total<br>do dia</div>
            </div>
            <div class="card-dia">
              <div class="card-dia-num" style="color:var(--red)"><span id="cd-pendente">0</span></div>
              <div class="card-dia-label">Pen-<br>dentes</div>
            </div>
            <div class="card-dia">
              <div class="card-dia-num" style="color:var(--amber)"><span id="cd-deslocamento">0</span></div>
              <div class="card-dia-label">Deslo-<br>camento</div>
            </div>
            <div class="card-dia">
              <div class="card-dia-num" style="color:var(--purple)"><span id="cd-agendada">0</span></div>
              <div class="card-dia-label">Agen-<br>dadas</div>
            </div>
            <div class="card-dia">
              <div class="card-dia-num" style="color:var(--blue)"><span id="cd-execucao">0</span></div>
              <div class="card-dia-label">Em<br>Execucao</div>
            </div>
            <div class="card-dia">
              <div class="card-dia-num" style="color:var(--green)"><span id="cd-finalizada">0</span></div>
              <div class="card-dia-label">Finali-<br>zadas</div>
            </div>
            <div class="card-dia" style="border-left:1px solid var(--border)">
              <div class="card-dia-num" style="color:var(--text2)"><span id="cd-tecnicos">0</span></div>
              <div class="card-dia-label">Tec em<br>deslocam.</div>
            </div>
          </div>
        </div>

      </div>

      <!-- SECAO FROTA -->
      <!-- SECAO REVISOES -->
      <div class="secao" id="secao-revisoes" style="padding:0;overflow:hidden;flex-direction:column">

        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;background:var(--surf);flex-shrink:0">
          <div style="font-weight:800;font-size:.95rem">🔧 Próximas Revisões</div>
          <div style="display:flex;gap:6px;margin-left:8px">
            <button class="btn btn-o active" id="rbtn-15" onclick="mudarFiltroRevisao(15,this)" style="padding:4px 10px;font-size:.75rem">15 dias</button>
            <button class="btn btn-o" id="rbtn-30" onclick="mudarFiltroRevisao(30,this)" style="padding:4px 10px;font-size:.75rem">30 dias</button>
            <button class="btn btn-o" id="rbtn-60" onclick="mudarFiltroRevisao(60,this)" style="padding:4px 10px;font-size:.75rem">60 dias</button>
            <button class="btn btn-o" id="rbtn-0" onclick="mudarFiltroRevisao(0,this)" style="padding:4px 10px;font-size:.75rem">Todos</button>
          </div>
          <div style="margin-left:auto;display:flex;gap:8px">
            <button class="btn btn-o" onclick="carregarRevisoes()" style="padding:4px 10px;font-size:.78rem">↻ Atualizar</button>
            <button class="btn btn-primary" onclick="abrirModalNovaRevisao()" style="padding:4px 12px;font-size:.78rem">+ Nova Revisão</button>
          </div>
        </div>

        <div id="rev-stats" style="display:flex;gap:10px;padding:14px 20px;border-bottom:1px solid var(--border);background:var(--surf2);flex-shrink:0;flex-wrap:wrap">
          <div class="rev-stat-card" style="border-color:#ef4444">
            <div class="rsc-num" id="rsc-num-vencido" style="color:#ef4444">0</div>
            <div class="rsc-label">🚨 Vencidos</div>
          </div>
          <div class="rev-stat-card" style="border-color:#f59e0b">
            <div class="rsc-num" id="rsc-num-urgente" style="color:#f59e0b">0</div>
            <div class="rsc-label">⚠️ Urgente (7d)</div>
          </div>
          <div class="rev-stat-card" style="border-color:#3b82f6">
            <div class="rsc-num" id="rsc-num-aviso" style="color:#3b82f6">0</div>
            <div class="rsc-label">📅 Aviso (15d)</div>
          </div>
          <div class="rev-stat-card" style="border-color:#22c55e">
            <div class="rsc-num" id="rsc-num-ok" style="color:#22c55e">0</div>
            <div class="rsc-label">✅ Em dia</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--border);margin-left:auto">
            <div class="rsc-num" id="rsc-num-total" style="color:var(--text)">0</div>
            <div class="rsc-label">Total itens</div>
          </div>
        </div>

        <div id="rev-lista" style="flex:1;overflow-y:auto;padding:16px 20px">
          <div style="text-align:center;color:var(--text3);padding:40px;font-size:.9rem">Carregando revisões...</div>
        </div>
      </div>

      <!-- MODAL NOVA/EDITAR REVISAO -->
      <div id="modal-revisao" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9100;align-items:center;justify-content:center">
        <div style="background:var(--surf);border:1px solid var(--border);border-radius:14px;padding:24px;width:460px;max-width:95vw;max-height:90vh;overflow-y:auto">
          <div style="font-weight:800;font-size:1rem;margin-bottom:18px" id="modal-rev-titulo">Nova Revisão</div>
          <input type="hidden" id="rev-id">
          <div style="display:grid;gap:12px">
            <div>
              <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Veículo *</label>
              <select id="rev-veiculo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none">
                <option value="">Selecione...</option>
              </select>
            </div>
            <div>
              <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Item de Revisão *</label>
              <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:6px" id="chips-itens">
                <span class="chip-item" onclick="toggleChip(this)">🛢️ Troca de óleo</span>
                <span class="chip-item" onclick="toggleChip(this)">🔧 Revisão geral</span>
                <span class="chip-item" onclick="toggleChip(this)">🔵 Filtro de óleo</span>
                <span class="chip-item" onclick="toggleChip(this)">💨 Filtro de ar</span>
                <span class="chip-item" onclick="toggleChip(this)">⛽ Filtro de combustível</span>
                <span class="chip-item" onclick="toggleChip(this)">🔋 Bateria</span>
                <span class="chip-item" onclick="toggleChip(this)">🔴 Pastilha de freio</span>
                <span class="chip-item" onclick="toggleChip(this)">⚙️ Correia dentada</span>
                <span class="chip-item" onclick="toggleChip(this)">🟡 Velas</span>
                <span class="chip-item" onclick="toggleChip(this)">🚗 Pneus</span>
                <span class="chip-item" onclick="toggleChip(this)">💧 Fluido de freio</span>
                <span class="chip-item" onclick="toggleChip(this)">❄️ Fluido de arrefecimento</span>
                <span class="chip-item" onclick="toggleChip(this)">📋 IPVA</span>
                <span class="chip-item" onclick="toggleChip(this)">📄 Licenciamento</span>
                <span class="chip-item" onclick="toggleChip(this)">🔦 Alinhamento/Balanceamento</span>
              </div>
              <input type="text" id="rev-item" placeholder="Ou digite um item personalizado..." style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
              <div style="font-size:.72rem;color:var(--text3);margin-top:4px">Clique nos itens acima para selecionar (pode selecionar vários) ou digite abaixo</div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div>
                <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Data prevista</label>
                <input type="date" id="rev-data" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
              </div>
              <div>
                <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">KM previsto</label>
                <input type="number" id="rev-km" placeholder="ex: 50000" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
              <div>
                <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Repetir a cada (dias)</label>
                <input type="number" id="rev-int-dias" placeholder="ex: 180" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
              </div>
              <div>
                <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Repetir a cada (km)</label>
                <input type="number" id="rev-int-km" placeholder="ex: 10000" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
              </div>
            </div>
            <div>
              <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Observação</label>
              <textarea id="rev-obs" rows="2" placeholder="Observações..." style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;resize:vertical;box-sizing:border-box"></textarea>
            </div>
          </div>
          <div style="display:flex;gap:8px;margin-top:18px;justify-content:flex-end">
            <button class="btn btn-o" onclick="fecharModalRevisao()">Cancelar</button>
            <button class="btn btn-primary" onclick="salvarRevisao()">Salvar</button>
          </div>
        </div>
      </div>

      <!-- MODAL REALIZAR REVISAO -->
      <div id="modal-realizar" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9100;align-items:center;justify-content:center">
        <div style="background:var(--surf);border:1px solid var(--border);border-radius:14px;padding:24px;width:380px;max-width:95vw">
          <div style="font-weight:800;font-size:.95rem;margin-bottom:4px">✅ Registrar Revisão Realizada</div>
          <div style="font-size:.8rem;color:var(--text3);margin-bottom:16px" id="realizar-info"></div>
          <input type="hidden" id="realizar-id">
          <div style="display:grid;gap:10px">
            <div>
              <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Data realizada *</label>
              <input type="date" id="realizar-data" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">KM na revisão</label>
              <input type="number" id="realizar-km" placeholder="KM atual do veiculo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;box-sizing:border-box">
            </div>
            <div>
              <label style="font-size:.78rem;color:var(--text3);display:block;margin-bottom:4px">Observação</label>
              <textarea id="realizar-obs" rows="2" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:8px;color:var(--text);padding:8px 10px;font-size:.85rem;outline:none;resize:vertical;box-sizing:border-box"></textarea>
            </div>
          </div>
          <div style="font-size:.75rem;color:var(--text3);margin-top:10px">Se houver intervalo configurado, a próxima revisão será calculada automaticamente.</div>
          <div style="display:flex;gap:8px;margin-top:16px;justify-content:flex-end">
            <button class="btn btn-o" onclick="fecharModalRealizar()">Cancelar</button>
            <button class="btn btn-primary" onclick="confirmarRealizacao()">Confirmar</button>
          </div>
        </div>
      </div>

      <div class="secao" id="secao-frota" style="flex-direction:row;overflow:hidden">

        <!-- SIDEBAR FROTA -->
        <div style="width:320px;background:var(--surf);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0">
          <div style="padding:12px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
            <div style="font-size:.85rem;font-weight:800">🚗 Veículos — <span id="frota-total">0</span></div>
            <button class="btn btn-o" style="padding:3px 8px;font-size:.75rem" onclick="syncVeiculos()">↻ Sync IXC</button>
          </div>
          <div style="padding:10px 12px;border-bottom:1px solid var(--border);background:var(--surf2)">
            <div style="font-size:.72rem;font-weight:700;color:var(--text3);text-transform:uppercase;margin-bottom:6px">Vínculos de Hoje</div>
            <div id="vinculos-hoje" style="display:flex;flex-direction:column;gap:4px"></div>
            <button class="btn btn-p" style="width:100%;margin-top:8px;padding:6px" onclick="abrirVincular()">+ Vincular Técnico ↔ Veículo</button>
          </div>
          <div style="flex:1;overflow-y:auto;padding:8px">
            <div id="lista-veiculos"></div>
          </div>
        </div>

        <!-- MAPA FROTA -->
        <div style="flex:1;position:relative">
          <div id="mapa-frota" style="width:100%;height:100%"></div>
          <div style="position:absolute;bottom:16px;right:16px;z-index:500;background:var(--surf);border:1px solid var(--border);border-radius:10px;padding:10px 14px;font-size:.75rem">
            <b style="display:block;margin-bottom:6px;font-size:.72rem;color:var(--text3);text-transform:uppercase">Técnicos</b>
            <div style="display:flex;align-items:center;gap:7px;margin-bottom:4px"><div style="width:12px;height:12px;border-radius:50%;background:var(--green)"></div>Em movimento</div>
            <div style="display:flex;align-items:center;gap:7px;margin-bottom:4px"><div style="width:12px;height:12px;border-radius:50%;background:var(--amber)"></div>Parado</div>
            <div style="display:flex;align-items:center;gap:7px"><div style="width:12px;height:12px;border-radius:50%;background:var(--red)"></div>Parado +30min</div>
          </div>
        </div>

      </div>

      <!-- SECAO DESPESAS -->
      <div class="secao" id="secao-despesas" style="padding:20px;overflow-y:auto">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px">
          <div style="font-size:1.1rem;font-weight:800">Despesas de Frota</div>
          <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
            <select id="desp-fil-veiculo" onchange="carregarDespesas()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
              <option value="">Todos os veiculos</option>
            </select>
            <input type="date" id="desp-fil-ini" onchange="carregarDespesas()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <span style="color:var(--text3);font-size:.75rem">ate</span>
            <input type="date" id="desp-fil-fim" onchange="carregarDespesas()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <button class="btn btn-p" onclick="abrirNovaDespesa()">+ Nova Despesa</button>
          </div>
        </div>
        <div id="desp-total" style="font-size:.82rem;color:var(--text3);margin-bottom:10px"></div>
        <div style="background:var(--surf);border:1px solid var(--border);border-radius:10px;overflow:hidden">
          <table>
            <thead><tr>
              <th>Data</th><th>Veiculo</th><th>Tipo</th><th>Descricao</th>
              <th>KM</th><th>Litros</th><th>Valor</th><th>IXC</th><th></th>
            </tr></thead>
            <tbody id="tbody-despesas"><tr><td colspan="9" style="text-align:center;color:var(--text3);padding:20px">Selecione Despesas no menu</td></tr></tbody>
          </table>
        </div>
      </div>

      <!-- SECAO ABASTECIMENTOS -->
      <div class="secao" id="secao-abastecimentos" style="padding:0;overflow:hidden;flex-direction:column">

        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--surf);flex-shrink:0;flex-wrap:wrap">
          <div style="font-weight:800;font-size:.95rem">Abastecimentos</div>
          <select id="abst-veiculo" onchange="carregarAbast()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <option value="">Todos os veiculos</option>
          </select>
          <select id="abst-mes" onchange="carregarAbast()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <option value="">Todos os meses</option>
            <option value="01">Janeiro</option><option value="02">Fevereiro</option>
            <option value="03">Marco</option><option value="04">Abril</option>
            <option value="05">Maio</option><option value="06">Junho</option>
            <option value="07">Julho</option><option value="08">Agosto</option>
            <option value="09">Setembro</option><option value="10">Outubro</option>
            <option value="11">Novembro</option><option value="12">Dezembro</option>
          </select>
          <input type="number" id="abst-ano" placeholder="Ano" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none;width:72px" onchange="carregarAbast()">
          <button class="btn btn-p" onclick="abrirNovoAbast()" style="margin-left:auto;padding:4px 12px;font-size:.78rem">+ Novo Abastecimento</button>
          <button class="btn btn-o" onclick="carregarAbast()" style="padding:4px 10px;font-size:.78rem">&#8635; Atualizar</button>
        </div>

        <div style="display:flex;gap:10px;padding:14px 20px;border-bottom:1px solid var(--border);background:var(--surf2);flex-shrink:0;flex-wrap:wrap">
          <div class="rev-stat-card" style="border-color:var(--blue)">
            <div class="rsc-num" id="abst-c-litros" style="color:var(--blue)">--</div>
            <div class="rsc-label">Total Litros</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--amber)">
            <div class="rsc-num" id="abst-c-gasto" style="color:var(--amber)">--</div>
            <div class="rsc-label">Total Gasto</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--green)">
            <div class="rsc-num" id="abst-c-kml" style="color:var(--green)">--</div>
            <div class="rsc-label">Media km/L</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--border)">
            <div class="rsc-num" id="abst-c-custoKm" style="color:var(--text)">--</div>
            <div class="rsc-label">Custo/km</div>
          </div>
          <div class="rev-stat-card" style="border-color:#ef4444">
            <div class="rsc-num" id="abst-c-alertas" style="color:#ef4444">0</div>
            <div class="rsc-label">Alertas consum.</div>
          </div>
        </div>

        <div style="flex:1;overflow-y:auto;padding:16px 20px">
          <div style="background:var(--surf);border:1px solid var(--border);border-radius:10px;overflow:hidden">
            <table>
              <thead><tr>
                <th>Data</th><th>Veiculo</th><th>KM</th><th>Litros</th>
                <th>Valor</th><th>R$/L</th><th>km/L</th><th></th>
              </tr></thead>
              <tbody id="tbody-abast"><tr><td colspan="8" style="text-align:center;color:var(--text3);padding:20px">Selecione Abastecimentos no menu</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- SECAO CHECKLISTS -->
      <div class="secao" id="secao-checklists" style="padding:0;overflow:hidden;flex-direction:column">

        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--surf);flex-shrink:0;flex-wrap:wrap">
          <div style="font-weight:800;font-size:.95rem">Checklists de Veiculo</div>
          <select id="chk-veiculo" onchange="carregarChecklists()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <option value="">Todos os veiculos</option>
          </select>
          <input type="date" id="chk-data" onchange="carregarChecklists()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
          <select id="chk-tipo" onchange="carregarChecklists()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <option value="">Saida + Retorno</option>
            <option value="saida">Saida</option>
            <option value="retorno">Retorno</option>
          </select>
          <button class="btn btn-p" onclick="abrirNovoChecklist()" style="margin-left:auto;padding:4px 12px;font-size:.78rem">+ Novo Checklist</button>
        </div>

        <div style="flex:1;overflow-y:auto;padding:16px 20px">
          <div id="chk-lista" style="display:flex;flex-direction:column;gap:12px">
            <div style="text-align:center;color:var(--text3);padding:40px">Selecione Checklists no menu</div>
          </div>
        </div>
      </div>

      <!-- SECAO CUSTOS -->
      <div class="secao" id="secao-custos" style="padding:0;overflow:hidden;flex-direction:column">

        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--surf);flex-shrink:0;flex-wrap:wrap">
          <div style="font-weight:800;font-size:.95rem">Custos da Frota</div>
          <select id="cst-mes" onchange="carregarCustos()" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none">
            <option value="">Todos os meses</option>
            <option value="01">Janeiro</option><option value="02">Fevereiro</option>
            <option value="03">Marco</option><option value="04">Abril</option>
            <option value="05">Maio</option><option value="06">Junho</option>
            <option value="07">Julho</option><option value="08">Agosto</option>
            <option value="09">Setembro</option><option value="10">Outubro</option>
            <option value="11">Novembro</option><option value="12">Dezembro</option>
          </select>
          <input type="number" id="cst-ano" placeholder="Ano" style="background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:4px 8px;font-size:.78rem;outline:none;width:72px" onchange="carregarCustos()">
          <button class="btn btn-o" onclick="carregarCustos()" style="padding:4px 10px;font-size:.78rem">&#8635; Atualizar</button>
        </div>

        <div style="display:flex;gap:10px;padding:14px 20px;border-bottom:1px solid var(--border);background:var(--surf2);flex-shrink:0;flex-wrap:wrap">
          <div class="rev-stat-card" style="border-color:var(--amber)">
            <div class="rsc-num" id="cst-t-total" style="color:var(--amber)">--</div>
            <div class="rsc-label">Total Geral</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--blue)">
            <div class="rsc-num" id="cst-t-comb" style="color:var(--blue)">--</div>
            <div class="rsc-label">Combustivel</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--green)">
            <div class="rsc-num" id="cst-t-manut" style="color:var(--green)">--</div>
            <div class="rsc-label">Manutencao</div>
          </div>
          <div class="rev-stat-card" style="border-color:var(--text3)">
            <div class="rsc-num" id="cst-t-outros" style="color:var(--text3)">--</div>
            <div class="rsc-label">Outros</div>
          </div>
          <div class="rev-stat-card" style="border-color:#ef4444">
            <div class="rsc-num" id="cst-t-acima" style="color:#ef4444">0</div>
            <div class="rsc-label">Veic. acima media</div>
          </div>
        </div>

        <div style="flex:1;overflow-y:auto;padding:16px 20px">
          <div style="background:var(--surf);border:1px solid var(--border);border-radius:10px;overflow:hidden">
            <table>
              <thead><tr>
                <th>Veiculo</th><th>Tipo</th>
                <th>Combustivel</th><th>Manutencao</th><th>Outros</th>
                <th>Total</th><th>vs. Media</th>
              </tr></thead>
              <tbody id="tbody-custos"><tr><td colspan="7" style="text-align:center;color:var(--text3);padding:20px">Selecione Custos no menu</td></tr></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- SECAO USUARIOS -->
      <div class="secao" id="secao-usuarios" style="padding:20px;overflow-y:auto">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
          <div style="font-size:1.1rem;font-weight:800">⚙️ Usuarios</div>
          <button class="btn btn-p" onclick="abrirNovoUsuario()">+ Novo</button>
        </div>
        <div style="background:var(--surf);border:1px solid var(--border);border-radius:10px;overflow:hidden">
          <table>
            <thead><tr><th>Nome</th><th>Login</th><th>Nivel</th><th>IXC ID</th><th>Status</th><th></th></tr></thead>
            <tbody id="tbody-usuarios"></tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
</div>

<!-- MODAL DETALHE OS -->
<div id="modal-detalhe">
  <div class="modal" style="max-width:500px">
    <div class="modal-title">
      <span id="md-titulo">OS #—</span>
      <button class="modal-close" onclick="fecharDetalhe()">✕</button>
    </div>
    <div id="md-status-badge" style="margin-bottom:14px"></div>
    <div id="md-body"></div>
    <hr class="detalhe-divider">
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button class="btn btn-o" onclick="fecharDetalhe()">Fechar</button>
      <button class="btn btn-p" id="md-btn-atribuir" onclick="abrirAtribuirDaModal()" style="display:none">Agendar Tecnico</button>
    </div>
  </div>
</div>

<!-- MODAL VINCULAR -->
<div class="modal-bg" id="modal-vincular">
  <div class="modal" style="max-width:420px">
    <div class="modal-title">
      <span>Vincular Técnico ↔ Veículo</span>
      <button class="modal-close" onclick="fecharVincular()">✕</button>
    </div>
    <div style="font-size:.75rem;color:var(--text3);margin-bottom:14px">Vínculo para hoje — <span id="vincular-data"></span></div>
    <div class="field"><label>Técnico</label><select id="vincular-tecnico" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none"></select></div>
    <div class="field"><label>Veículo</label><select id="vincular-veiculo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none"></select></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px">
      <button class="btn btn-o" onclick="fecharVincular()">Cancelar</button>
      <button class="btn btn-p" onclick="salvarVinculo()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL ATRIBUIR -->
<div class="modal-bg" id="modal-atribuir">
  <div class="modal">
    <div class="modal-title">
      <span>Atribuir Tecnico — OS <span id="modal-os-num"></span></span>
      <button class="modal-close" onclick="fecharModal()">✕</button>
    </div>
    <div class="field">
      <label>Data Reservada</label>
      <input type="datetime-local" id="inp-data-reservada">
    </div>
    <div style="font-size:.73rem;color:var(--text3);font-weight:700;text-transform:uppercase;margin-bottom:8px">Tecnicos Disponiveis</div>
    <div id="lista-tecnicos-modal"></div>
  </div>
</div>

<!-- MODAL USUARIO -->
<div class="modal-bg" id="modal-usuario">
  <div class="modal">
    <div class="modal-title">
      <span id="modal-user-titulo">Novo Usuario</span>
      <button class="modal-close" onclick="fecharModalUsuario()">✕</button>
    </div>
    <input type="hidden" id="mu-id">
    <div class="field"><label>Nome</label><input type="text" id="mu-nome"></div>
    <div class="field"><label>Login</label><input type="text" id="mu-login"></div>
    <div class="field"><label>Senha (em branco = manter)</label><input type="password" id="mu-senha"></div>
    <div class="field"><label>Nivel</label>
      <select id="mu-nivel">
        <option value="10">Tecnico (10)</option>
        <option value="40">Frota (40)</option>
        <option value="50">Supervisor (50)</option>
        <option value="99">Admin (99)</option>
      </select>
    </div>
    <div class="field"><label>IXC Funcionario ID</label><input type="number" id="mu-ixc"></div>
    <div class="field"><label>Status</label>
      <select id="mu-ativo"><option value="1">Ativo</option><option value="0">Inativo</option></select>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
      <button class="btn btn-o" onclick="fecharModalUsuario()">Cancelar</button>
      <button class="btn btn-p" onclick="salvarUsuario()">Salvar</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
// ── ESTADO GLOBAL ─────────────────────────────────────────────
var usuario = null;
var osCache = [], tecnicosCache = [], marcadores = {}, marcadoresTec = {};
var mapa = null, osAtribuirId = null, osSelecionadaId = null;
var filtros = new Set(['pendente','deslocamento','agendada','reagendada','execucao']);
var tipoFiltro = 'todos';
var rotasTecnicos = {};
var _usuarios = [];
var _intervaloDados = null;

// ── ASSUNTO → TIPO ────────────────────────────────────────────
var ASSUNTO_TIPO = {
  5:'suporte',17:'suporte',20:'suporte',21:'suporte',27:'suporte',44:'suporte',
  47:'suporte',94:'suporte',102:'suporte',103:'suporte',104:'suporte',105:'suporte',
  107:'suporte',113:'suporte',184:'suporte',203:'suporte',240:'suporte',
  245:'suporte',248:'suporte',226:'suporte',
  3:'infra',7:'infra',16:'infra',53:'infra',138:'infra',142:'infra',143:'infra',
  145:'infra',146:'infra',148:'infra',151:'infra',152:'infra',153:'infra',154:'infra',
  155:'infra',156:'infra',157:'infra',158:'infra',159:'infra',160:'infra',161:'infra',
  162:'infra',163:'infra',164:'infra',165:'infra',166:'infra',167:'infra',168:'infra',
  169:'infra',170:'infra',171:'infra',172:'infra',173:'infra',174:'infra',175:'infra',
  176:'infra',177:'infra',178:'infra',179:'infra',180:'infra',181:'infra',182:'infra',
  183:'infra',185:'infra',186:'infra',187:'infra',188:'infra',221:'infra',222:'infra',
  232:'infra',242:'infra',243:'infra',244:'infra',247:'infra',
  2:'instalacao',14:'instalacao',15:'instalacao',18:'instalacao',19:'instalacao',
  26:'instalacao',30:'instalacao',48:'instalacao',49:'instalacao',92:'instalacao',
  101:'instalacao',110:'instalacao',220:'instalacao',227:'instalacao',239:'instalacao',
  6:'retirada',22:'retirada',39:'retirada',40:'retirada',89:'retirada',
  111:'retirada',127:'retirada'
};

// ── AUTH ──────────────────────────────────────────────────────
function token() {
  return localStorage.getItem('ht_hub_token') || localStorage.getItem('ht_despacho_token') || '';
}
function api(path, opts) {
  opts = opts || {};
  return fetch(path, Object.assign({}, opts, {
    headers: Object.assign({'Content-Type':'application/json','Authorization':'Bearer '+token()}, opts.headers||{})
  })).then(function(r){ return r.json(); });
}

// ── LOGIN ─────────────────────────────────────────────────────
document.addEventListener('keydown', function(e){
  if (e.key==='Enter' && document.getElementById('P-LOGIN').style.display!=='none') fazerLogin();
});

async function fazerLogin() {
  var login = document.getElementById('inp-login').value.trim();
  var senha = document.getElementById('inp-senha').value;
  var err = document.getElementById('login-err');
  err.style.display = 'none';
  if (!login||!senha) { err.textContent='Preencha login e senha'; err.style.display='block'; return; }
  try {
    var r = await fetch('/api/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({login:login,senha:senha})}).then(function(r){return r.json();});
    if (r.detail) { err.textContent=r.detail; err.style.display='block'; return; }
    if (r.usuario.nivel < 40) { err.textContent='Acesso negado. Use o app do tecnico.'; err.style.display='block'; return; }
    localStorage.setItem('ht_hub_token', r.token);
    localStorage.setItem('ht_hub_usuario', JSON.stringify(r.usuario));
    localStorage.setItem('ht_despacho_token', r.token);
    localStorage.setItem('ht_despacho_usuario', JSON.stringify(r.usuario));
    iniciarApp(r.usuario);
  } catch(e) { err.textContent='Erro de conexao'; err.style.display='block'; }
}

function iniciarApp(u) {
  usuario = u;
  document.getElementById('P-LOGIN').style.display = 'none';
  document.getElementById('P-APP').style.display = 'block';
  document.getElementById('sb-nome').textContent = u.nome;
  document.getElementById('sb-avatar').textContent = u.nome.charAt(0).toUpperCase();
  var roles = {10:'Tecnico',40:'Frota',50:'Supervisor',99:'Admin'};
  document.getElementById('sb-role').textContent = roles[u.nivel] || 'Usuario';
  if (u.nivel >= 50) { document.getElementById('grp-os').style.display='block'; document.getElementById('ni-os').style.display='flex'; }
  if (u.nivel >= 40) {
    document.getElementById('grp-frota').style.display='block';
    document.getElementById('ni-frota').style.display='flex';
    document.getElementById('ni-revisoes').style.display='flex';
    document.getElementById('ni-custos').style.display='flex';
    document.getElementById('ni-checklists').style.display='flex';
    document.getElementById('ni-abastecimentos').style.display='flex';
    document.getElementById('ni-despesas').style.display='flex';
  }
  if (u.nivel >= 99) { document.getElementById('grp-admin').style.display='block'; document.getElementById('ni-usuarios').style.display='flex'; }
  if (u.nivel >= 50) { navTo('os'); } else if (u.nivel >= 40) { navTo('frota'); }
}

function navTo(secao) {
  document.querySelectorAll('.secao').forEach(function(s){s.classList.remove('ativa');});
  document.querySelectorAll('.ni').forEach(function(n){n.classList.remove('active');});
  var s = document.getElementById('secao-'+secao);
  var n = document.getElementById('ni-'+secao) || document.getElementById('ni-usuarios');
  if (s) s.classList.add('ativa');
  if (n) n.classList.add('active');
  if (_intervaloDados) { clearInterval(_intervaloDados); _intervaloDados = null; }
  if (secao==='os') {
    document.getElementById('tb-stats-os').style.display = 'flex';
    document.getElementById('tb-titulo').textContent = 'Controle de OS';
    if (!mapa) iniciarMapa();
    carregarDados();
    _intervaloDados = setInterval(carregarDados, 30000);
  } else if (secao==='frota') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Controle de Frota';
    setTimeout
// ── ABASTECIMENTOS ────────────────────────────────────────────
var _veiculosAbast = [];

async function carregarAbast() {
  if (_veiculosAbast.length === 0) {
    _veiculosAbast = await api('/api/despesas/veiculos');
    var sel = document.getElementById('abst-veiculo');
    if (sel) {
      sel.innerHTML = '<option value="">Todos os veiculos</option>';
      _veiculosAbast.forEach(function(v) {
        sel.innerHTML += '<option value="' + v.ixc_veiculo_id + '">' + v.placa + ' -- ' + v.marca_modelo + '</option>';
      });
    }
    var anoEl = document.getElementById('abst-ano');
    if (anoEl && !anoEl.value) anoEl.value = new Date().getFullYear();
  }

  var veiculo = document.getElementById('abst-veiculo').value;
  var mes = document.getElementById('abst-mes').value;
  var ano = document.getElementById('abst-ano').value;

  var url = '/api/abastecimentos?x=1';
  if (veiculo) url += '&id_veiculo=' + veiculo;
  if (mes) url += '&mes=' + mes;
  if (ano) url += '&ano=' + ano;

  var rows = await api(url);
  if (!Array.isArray(rows)) rows = [];

  var totalLitros = 0, totalGasto = 0, somaKml = 0, nKml = 0, kmTotal = 0, alertas = 0;
  rows.forEach(function(r) {
    totalLitros += r.quantidade_litros || 0;
    totalGasto += r.valor || 0;
    if (r.km_por_litro) { somaKml += r.km_por_litro; nKml++; }
    if (r.km_rodados) kmTotal += r.km_rodados;
    if (r.alerta_consumo) alertas++;
  });
  var mediaKml = nKml ? somaKml / nKml : null;
  var custoKm = kmTotal > 0 ? totalGasto / kmTotal : null;

  document.getElementById('abst-c-litros').textContent = totalLitros.toFixed(1) + ' L';
  document.getElementById('abst-c-gasto').textContent = 'R$ ' + totalGasto.toFixed(2).replace('.', ',');
  document.getElementById('abst-c-kml').textContent = mediaKml ? mediaKml.toFixed(2) + ' km/L' : '--';
  document.getElementById('abst-c-custoKm').textContent = custoKm ? 'R$ ' + custoKm.toFixed(4) : '--';
  document.getElementById('abst-c-alertas').textContent = alertas;

  var tb = '';
  rows.forEach(function(r) {
    var kml = r.km_por_litro ? r.km_por_litro.toFixed(2) : '--';
    var kmlColor = r.km_por_litro ? (r.alerta_consumo ? '#ef4444' : 'var(--green)') : 'var(--text3)';
    var alerta = r.alerta_consumo
      ? '<span title="Consumo ' + (r.km_por_litro||0).toFixed(2) + ' km/L vs media ' + (r.media_km_litro||0).toFixed(2) + ' km/L" style="color:#ef4444">&#9888;</span>'
      : '';
    tb += '<tr>'
      + '<td>' + r.data + '</td>'
      + '<td style="font-size:.78rem">' + (r.placa || '--') + '</td>'
      + '<td style="color:var(--text3);font-size:.78rem">' + (r.kilometragem ? Number(r.kilometragem).toLocaleString() + ' km' : '--') + '</td>'
      + '<td>' + Number(r.quantidade_litros).toFixed(2) + ' L</td>'
      + '<td style="font-weight:700;color:var(--amber)">R$ ' + Number(r.valor).toFixed(2).replace('.', ',') + '</td>'
      + '<td style="font-size:.78rem;color:var(--text3)">' + (r.valor_litro ? 'R$ ' + Number(r.valor_litro).toFixed(3) : '--') + '</td>'
      + '<td style="font-weight:700;color:' + kmlColor + '">' + kml + '</td>'
      + '<td>' + alerta + '</td>'
      + '</tr>';
  });
  if (!tb) tb = '<tr><td colspan="8" style="text-align:center;color:var(--text3);padding:20px">Nenhum abastecimento encontrado no periodo</td></tr>';
  document.getElementById('tbody-abast').innerHTML = tb;
}

function abrirNovoAbast() {
  abrirNovaDespesa();
  setTimeout(function() {
    var el = document.getElementById('d-tipo');
    if (el) { el.value = 'Abastecimento'; mostrarCamposAbast(); }
  }, 80);
}



// ── CHECKLISTS ────────────────────────────────────────────────
var _veiculosChk = [];
var _itensChkPadrao = [];

async function carregarChecklists() {
  if (_veiculosChk.length === 0) {
    _veiculosChk = await api('/api/despesas/veiculos');
    var sel = document.getElementById('chk-veiculo');
    if (sel) {
      sel.innerHTML = '<option value="">Todos os veiculos</option>';
      _veiculosChk.forEach(function(v) {
        sel.innerHTML += '<option value="' + v.id + '">' + v.placa + ' -- ' + v.marca_modelo + '</option>';
      });
    }
    var dEl = document.getElementById('chk-data');
    if (dEl && !dEl.value) dEl.value = new Date().toISOString().split('T')[0];
  }

  var veiculo = document.getElementById('chk-veiculo').value;
  var data = document.getElementById('chk-data').value;
  var tipo = document.getElementById('chk-tipo').value;
  var url = '/api/checklists?x=1';
  if (veiculo) url += '&id_veiculo=' + veiculo;
  if (data) url += '&data=' + data;
  if (tipo) url += '&tipo=' + tipo;

  var rows = await api(url);
  if (!Array.isArray(rows)) rows = [];

  var lista = document.getElementById('chk-lista');
  if (!rows.length) {
    lista.innerHTML = '<div style="text-align:center;color:var(--text3);padding:40px">Nenhum checklist encontrado</div>';
    return;
  }

  var html = '';
  rows.forEach(function(r) {
    var itens = [];
    try { itens = JSON.parse(r.itens_json || '[]'); } catch(e) {}
    var cor = r.itens_nao_ok > 0 ? '#ef4444' : 'var(--green)';
    var badge = r.itens_nao_ok > 0
      ? '<span style="background:#ef444420;color:#ef4444;font-size:.72rem;padding:2px 8px;border-radius:4px;font-weight:700">' + r.itens_nao_ok + ' item(ns) NOK</span>'
      : '<span style="background:var(--green)20;color:var(--green);font-size:.72rem;padding:2px 8px;border-radius:4px;font-weight:700">Tudo OK</span>';
    var tipoBadge = r.tipo === 'saida'
      ? '<span style="background:var(--blue)20;color:var(--blue);font-size:.72rem;padding:2px 8px;border-radius:4px">Saida</span>'
      : '<span style="background:var(--amber)20;color:var(--amber);font-size:.72rem;padding:2px 8px;border-radius:4px">Retorno</span>';

    html += '<div style="background:var(--surf);border:1px solid var(--border);border-left:4px solid ' + cor + ';border-radius:10px;padding:14px">';
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap">';
    html += '<span style="font-weight:700">' + (r.placa || '--') + '</span>';
    html += '<span style="color:var(--text3);font-size:.78rem">' + (r.marca_modelo || '') + '</span>';
    html += tipoBadge + badge;
    html += '<span style="margin-left:auto;font-size:.75rem;color:var(--text3)">' + r.data + (r.km ? ' &bull; ' + r.km.toLocaleString() + ' km' : '') + '</span>';
    html += '<span style="font-size:.75rem;color:var(--text3)">' + (r.tecnico_nome || '--') + '</span>';
    html += '</div>';

    if (itens.length) {
      html += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
      itens.forEach(function(it) {
        var c = it.ok ? 'var(--green)' : '#ef4444';
        html += '<span style="font-size:.72rem;padding:2px 8px;border-radius:4px;background:' + c + '20;color:' + c + '">'
          + (it.ok ? '&#10003;' : '&#10007;') + ' ' + it.item
          + (it.obs ? ' (' + it.obs + ')' : '') + '</span>';
      });
      html += '</div>';
    }
    if (r.observacao) html += '<div style="font-size:.78rem;color:var(--text3);margin-top:6px">' + r.observacao + '</div>';
    html += '</div>';
  });
  lista.innerHTML = html;
}

async function abrirNovoChecklist() {
  if (_itensChkPadrao.length === 0) {
    _itensChkPadrao = await api('/api/checklists/itens-padrao');
  }
  if (_veiculosChk.length === 0) {
    _veiculosChk = await api('/api/despesas/veiculos');
  }
  var selV = document.getElementById('chk-m-veiculo');
  selV.innerHTML = '<option value="">Selecione...</option>';
  _veiculosChk.forEach(function(v) {
    selV.innerHTML += '<option value="' + v.id + '">' + v.placa + ' -- ' + v.marca_modelo + '</option>';
  });

  var itensDiv = document.getElementById('chk-m-itens');
  itensDiv.innerHTML = '';
  _itensChkPadrao.forEach(function(item, i) {
    itensDiv.innerHTML += '<div style="display:flex;align-items:center;gap:10px;padding:6px 10px;background:var(--surf2);border-radius:7px">'
      + '<input type="checkbox" id="chki-' + i + '" checked style="width:16px;height:16px;accent-color:var(--accent)">'
      + '<label for="chki-' + i + '" style="flex:1;font-size:.85rem;cursor:pointer">' + item + '</label>'
      + '<input type="text" placeholder="Obs" id="chko-' + i + '" style="width:120px;background:var(--surf);border:1px solid var(--border);border-radius:5px;color:var(--text);padding:3px 7px;font-size:.75rem;outline:none">'
      + '</div>';
  });

  document.getElementById('chk-m-km').value = '';
  document.getElementById('chk-m-obs').value = '';
  document.getElementById('chk-erro').style.display = 'none';
  document.getElementById('modal-checklist').classList.add('open');
}

function fecharChecklist() {
  document.getElementById('modal-checklist').classList.remove('open');
}

async function salvarChecklist() {
  var erro = document.getElementById('chk-erro');
  erro.style.display = 'none';
  var veiculo = document.getElementById('chk-m-veiculo').value;
  if (!veiculo) { erro.textContent = 'Selecione o veiculo.'; erro.style.display = 'block'; return; }
  var itens = _itensChkPadrao.map(function(item, i) {
    return {
      item: item,
      ok: document.getElementById('chki-' + i).checked,
      obs: document.getElementById('chko-' + i).value.trim()
    };
  });
  var body = {
    id_veiculo: parseInt(veiculo),
    tipo: document.getElementById('chk-m-tipo').value,
    km: parseInt(document.getElementById('chk-m-km').value) || null,
    itens: itens,
    observacao: document.getElementById('chk-m-obs').value.trim()
  };
  var r = await api('/api/checklists', {method: 'POST', body: JSON.stringify(body)});
  if (r && r.ok) {
    fecharChecklist();
    carregarChecklists();
    var nok = itens.filter(function(i){return !i.ok;}).length;
    toast('Checklist salvo' + (nok ? ' — ' + nok + ' item(ns) NOK' : ' — Tudo OK'), 'ok');
  } else {
    erro.textContent = (r && r.detail) || 'Erro ao salvar';
    erro.style.display = 'block';
  }
}



// ── CUSTOS ───────────────────────────────────────────────────
async function carregarCustos() {
  var anoEl = document.getElementById('cst-ano');
  if (anoEl && !anoEl.value) anoEl.value = new Date().getFullYear();
  var mes = document.getElementById('cst-mes').value;
  var ano = document.getElementById('cst-ano').value;

  var url = '/api/custos?x=1';
  if (mes) url += '&mes=' + mes;
  if (ano) url += '&ano=' + ano;

  var rows = await api(url);
  if (!Array.isArray(rows)) rows = [];

  var totalGeral = 0, totalComb = 0, totalManut = 0, totalOutros = 0;
  rows.forEach(function(r) {
    totalGeral  += r.total || 0;
    totalComb   += r.combustivel || 0;
    totalManut  += r.manutencao || 0;
    totalOutros += r.outros || 0;
  });
  var media = rows.length ? totalGeral / rows.length : 0;
  var acimaMedia = rows.filter(function(r){ return r.total > media * 1.2; }).length;

  function fmt(v) { return 'R$ ' + (v||0).toFixed(2).replace('.',','); }
  document.getElementById('cst-t-total').textContent  = fmt(totalGeral);
  document.getElementById('cst-t-comb').textContent   = fmt(totalComb);
  document.getElementById('cst-t-manut').textContent  = fmt(totalManut);
  document.getElementById('cst-t-outros').textContent = fmt(totalOutros);
  document.getElementById('cst-t-acima').textContent  = acimaMedia;

  var tb = '';
  rows.forEach(function(r) {
    var pct = media > 0 ? ((r.total - media) / media * 100) : 0;
    var pctTxt = pct > 0 ? '+' + pct.toFixed(0) + '%' : pct.toFixed(0) + '%';
    var pctColor = pct > 20 ? '#ef4444' : pct < -10 ? 'var(--green)' : 'var(--text3)';
    tb += '<tr>'
      + '<td style="font-weight:700">' + (r.placa||'--') + '<br><span style="font-weight:400;color:var(--text3);font-size:.72rem">' + (r.marca_modelo||'') + '</span></td>'
      + '<td style="font-size:.75rem;color:var(--text3)">' + (r.tipo_veiculo||'--') + '</td>'
      + '<td style="color:var(--blue)">' + fmt(r.combustivel) + '</td>'
      + '<td style="color:var(--green)">' + fmt(r.manutencao) + '</td>'
      + '<td style="color:var(--text3)">' + fmt(r.outros) + '</td>'
      + '<td style="font-weight:800;color:var(--amber)">' + fmt(r.total) + '</td>'
      + '<td style="font-weight:700;color:' + pctColor + '">' + (media > 0 ? pctTxt : '--') + '</td>'
      + '</tr>';
  });
  if (!tb) tb = '<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:20px">Nenhum dado de custo encontrado no periodo</td></tr>';
  document.getElementById('tbody-custos').innerHTML = tb;
}


(function(){
      iniciarMapaFrota();
      carregarFrota();
    }, 100);
  } else if (secao==='despesas') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Despesas de Frota';
    carregarDespesas();
  } else if (secao==='custos') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Custos da Frota';
    carregarCustos();
  } else if (secao==='checklists') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Checklists de Veiculo';
    carregarChecklists();
  } else if (secao==='abastecimentos') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Abastecimentos';
    carregarAbast();
  } else if (secao==='revisoes') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Próximas Revisões';
    carregarRevisoes();
  } else if (secao==='usuarios') {
    document.getElementById('tb-stats-os').style.display = 'none';
    document.getElementById('tb-titulo').textContent = 'Usuarios';
    carregarUsuarios();
  }
}

function toggleSidebar() { document.getElementById('sidebar').classList.toggle('collapsed'); }
function logout() {
  if (_intervaloDados) clearInterval(_intervaloDados);
  ['ht_hub_token','ht_hub_usuario','ht_despacho_token','ht_despacho_usuario'].forEach(function(k){localStorage.removeItem(k);});
  location.reload();
}

// ── MAPA ──────────────────────────────────────────────────────
function iniciarMapa() {
  mapa = L.map('mapa').setView([-15.7942, -47.8825], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© OpenStreetMap', maxZoom:19
  }).addTo(mapa);
}

function iconeOS(status) {
  var cores = {pendente:'#ff4d6a',deslocamento:'#ffb83f',agendada:'#a78bfa',reagendada:'#a78bfa',execucao:'#60a5fa',finalizada:'#00e5a0'};
  var cor = cores[status] || '#6b7590';
  return L.divIcon({
    className:'',
    html:'<div style="background:'+cor+';width:14px;height:14px;border-radius:50%;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.5)"></div>',
    iconSize:[14,14], iconAnchor:[7,7]
  });
}

function iconeTecnico(tec) {
  var agora = new Date();
  var regEm = tec.registrado_em ? new Date(tec.registrado_em) : null;
  var minParado = regEm ? Math.floor((agora - regEm) / 60000) : 999;
  var vel = parseFloat(tec.velocidade) || 0;
  var cor, emoji;
  if (vel > 3) {
    cor = '#00e5a0'; emoji = '🚗';
  } else if (minParado >= 30) {
    cor = '#ff4d6a'; emoji = '⏱️';
  } else {
    cor = '#ffb83f'; emoji = '🅿️';
  }
  var label = tec.tecnico_nome ? tec.tecnico_nome.split(' ')[0] : '';
  return L.divIcon({
    className:'',
    html:'<div style="background:var(--surf2);border:2px solid '+cor+';border-radius:8px;padding:2px 7px;font-size:11px;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.5);color:#fff;font-weight:700">'+emoji+' '+label+'</div>',
    iconSize:[80,26], iconAnchor:[40,13]
  });
}

// ── DADOS ─────────────────────────────────────────────────────
async function carregarDados() {
  try {
    var dados = await api('/api/despacho/mapa');
    var gps = await api('/api/gps/posicoes');
    osCache = dados.os || [];
    tecnicosCache = gps || [];
    rotasTecnicos = {};
    try {
      var ids = [];
      tecnicosCache.forEach(function(t){ if (t.id_tecnico && ids.indexOf(t.id_tecnico)<0) ids.push(t.id_tecnico); });
      for (var i=0; i<ids.length; i++) {
        try {
          var pontos = await api('/api/gps/rota/'+ids[i]);
          if (pontos && pontos.length) rotasTecnicos[ids[i]] = pontos;
        } catch(e) {}
      }
    } catch(e) {}
    atualizarStats(dados.stats || {});
    renderSidebar();
    renderMapa();
  } catch(e) { console.log('Erro ao carregar:', e); }
}

function limparDatas() {
  document.getElementById('filtro-data-ini').value = '';
  document.getElementById('filtro-data-fim').value = '';
  renderSidebar(); renderMapa();
}

function passaFiltroData(o) {
  var ini = document.getElementById('filtro-data-ini').value;
  var fim = document.getElementById('filtro-data-fim').value;
  if (!ini && !fim) return true;
  var dataOs = (o.data_reservada||o.data_abertura||'').substring(0,10);
  if (!dataOs) return true;
  if (ini && dataOs < ini) return false;
  if (fim && dataOs > fim) return false;
  return true;
}

function atualizarStats(s) {
  var pend = s.pendentes||0, desl = s.deslocamento||0, exec = s.execucao||0, fin = s.finalizadas||0;
  var agend = osCache.filter(function(o){ return o.status_hub==='agendada'||o.status_hub==='reagendada'; }).length;
  var total = pend+desl+agend+exec+fin;
  var tecDesl = tecnicosCache.filter(function(t){ return parseFloat(t.velocidade||0)>3; }).length;

  // topbar pills
  document.getElementById('cnt-pendente').textContent = pend;
  document.getElementById('cnt-deslocamento').textContent = desl;
  document.getElementById('cnt-agendada').textContent = agend;
  document.getElementById('cnt-execucao').textContent = exec;

  // sidebar stats
  document.getElementById('st-total').textContent = total;
  document.getElementById('st-pendente').textContent = pend;
  document.getElementById('st-deslocamento').textContent = desl;
  document.getElementById('st-agendada').textContent = agend;
  document.getElementById('st-execucao').textContent = exec;
  document.getElementById('st-finalizada').textContent = fin;
  document.getElementById('st-tecnicos').textContent = tecnicosCache.length;

  // cards dia
  document.getElementById('cd-total').textContent = total;
  document.getElementById('cd-pendente').textContent = pend;
  document.getElementById('cd-deslocamento').textContent = desl;
  document.getElementById('cd-agendada').textContent = agend;
  document.getElementById('cd-execucao').textContent = exec;
  document.getElementById('cd-finalizada').textContent = fin;
  document.getElementById('cd-tecnicos').textContent = tecDesl;
}

// ── SIDEBAR OS ────────────────────────────────────────────────
function renderSidebar() {
  var filtradas = osCache.filter(function(o) {
    if (!passaFiltroData(o)) return false;
    if (!filtros.has(o.status_hub)) return false;
    if (tipoFiltro !== 'todos') {
      var tipo = ASSUNTO_TIPO[o.id_assunto] || 'default';
      if (tipo !== tipoFiltro) return false;
    }
    return true;
  });
  var lista = document.getElementById('lista-os');
  if (!filtradas.length) {
    lista.innerHTML = '<div style="padding:20px;color:var(--text3);font-size:.85rem;text-align:center">Nenhuma OS</div>';
    return;
  }
  var html = '';
  filtradas.forEach(function(o) {
    html += '<div class="os-item" data-id="'+o.ixc_os_id+'" onclick="selecionarOS('+o.ixc_os_id+')" id="osi-'+o.ixc_os_id+'">';
    html += '<div class="os-item-top">';
    html += '<span class="os-num">OS #'+o.ixc_os_id+'</span>';
    html += '<span class="os-badge badge-'+o.status_hub+'">'+labelStatus(o.status_hub)+'</span>';
    html += '</div>';
    html += '<div class="os-cliente">'+(o.cliente_nome||'—')+'</div>';
    html += '<div class="os-end">📍 '+(o.endereco||'—')+(o.bairro?' · '+o.bairro:'')+'</div>';
    html += '<div class="os-meta"><span>'+(o.assunto_nome||'—')+'</span><span>'+(o.tecnico_nome||'Sem tecnico')+'</span></div>';
    html += '</div>';
  });
  lista.innerHTML = html;
  if (osSelecionadaId) {
    var el = document.getElementById('osi-'+osSelecionadaId);
    if (el) el.classList.add('selected');
  }
}

// ── MAPA ──────────────────────────────────────────────────────
function renderMapa() {
  if (!mapa) return;
  Object.values(marcadores).forEach(function(m){ mapa.removeLayer(m); });
  Object.values(marcadoresTec).forEach(function(m){ mapa.removeLayer(m); });
  marcadores = {}; marcadoresTec = {};

  // OS
  osCache.forEach(function(o) {
    if (!filtros.has(o.status_hub)) return;
    if (!passaFiltroData(o)) return;
    if (tipoFiltro !== 'todos') {
      var tipo = ASSUNTO_TIPO[o.id_assunto] || 'default';
      if (tipo !== tipoFiltro) return;
    }
    if (!o.lat || !o.lon) return;
    var m = L.marker([o.lat, o.lon], {icon: iconeOS(o.status_hub)})
      .addTo(mapa)
      .bindTooltip('<b>OS #'+o.ixc_os_id+'</b><br>'+(o.cliente_nome||'')+'<br>'+(o.assunto_nome||''), {direction:'top'});
    (function(osId){ m.on('click', function(){ selecionarOS(osId); }); })(o.ixc_os_id);
    marcadores[o.ixc_os_id] = m;

    if (o.sla_estourado) {
      var circle = L.circle([o.lat, o.lon], {radius:300,color:'#ef4444',fillColor:'#ef4444',fillOpacity:.1,weight:2}).addTo(mapa);
      marcadores['sla_'+o.ixc_os_id] = circle;
    }
  });

  // Rotas dos tecnicos
  Object.keys(rotasTecnicos).forEach(function(id) {
    var pontos = rotasTecnicos[id];
    if (!pontos || pontos.length < 2) return;
    var linha = L.polyline(pontos.map(function(p){ return [p.lat,p.lon]; }), {
      color:'#ffb83f', weight:2, opacity:0.5, dashArray:'5,5'
    }).addTo(mapa);
    marcadoresTec['rota_'+id] = linha;
  });

  // Tecnicos (veiculos)
  tecnicosCache.forEach(function(t) {
    if (!t.lat || !t.lon) return;
    var agora = new Date();
    var regEm = t.registrado_em ? new Date(t.registrado_em) : null;
    var minParado = regEm ? Math.floor((agora - regEm) / 60000) : 999;
    var vel = parseFloat(t.velocidade) || 0;
    var statusTxt = vel > 3 ? 'Em movimento ('+Math.round(vel)+' km/h)' : (minParado >= 30 ? 'Parado ha '+minParado+' min' : 'Parado');
    var m = L.marker([t.lat, t.lon], {icon: iconeTecnico(t), zIndexOffset:1000})
      .addTo(mapa)
      .bindTooltip('<b>'+t.tecnico_nome+'</b><br>'+statusTxt+'<br>'+(t.registrado_em||''), {direction:'top'});
    marcadoresTec[t.id_tecnico] = m;
  });
}

// ── SELECIONAR OS ─────────────────────────────────────────────
function selecionarOS(ixc_os_id) {
  var os = osCache.find(function(o){ return o.ixc_os_id===ixc_os_id; });
  if (!os) return;
  osSelecionadaId = ixc_os_id;
  document.querySelectorAll('.os-item').forEach(function(i){ i.classList.remove('selected'); });
  var el = document.getElementById('osi-'+ixc_os_id);
  if (el) { el.classList.add('selected'); el.scrollIntoView({block:'nearest'}); }
  if (os.lat && os.lon) mapa.setView([os.lat, os.lon], 15);
  mostrarDetalhesOS(os);
}

function mostrarDetalhesOS(os) {
  document.getElementById('md-titulo').textContent = 'OS #'+os.ixc_os_id;
  var badge = '<span class="os-badge badge-'+os.status_hub+'" style="font-size:.82rem;padding:4px 10px">'+labelStatusFull(os.status_hub)+'</span>';
  document.getElementById('md-status-badge').innerHTML = badge;

  var dr = os.data_reservada ? os.data_reservada.substring(0,16).replace('T',' ') : '—';
  var da = os.data_abertura ? os.data_abertura.substring(0,16).replace('T',' ') : '—';

  var html = '';
  html += row('Cliente', os.cliente_nome||'—');
  html += row('Endereco', (os.endereco||'—')+(os.bairro?' — '+os.bairro:''));
  html += row('Assunto', os.assunto_nome||'—');
  html += row('Tecnico', os.tecnico_nome||'Sem tecnico');
  html += row('Abertura', da);
  html += row('Agendada', dr);
  if (os.obs_abertura) html += row('Obs', os.obs_abertura);
  if (os.motivo_reagendamento) html += row('Reagend.', os.motivo_reagendamento);

  document.getElementById('md-body').innerHTML = html;

  var btnAtribuir = document.getElementById('md-btn-atribuir');
  btnAtribuir.style.display = (os.status_hub==='pendente'||os.status_hub==='agendada'||os.status_hub==='reagendada') ? 'inline-block' : 'none';

  document.getElementById('modal-detalhe').classList.add('open');
}

function row(label, val) {
  return '<div class="detalhe-row"><div class="detalhe-label">'+label+'</div><div class="detalhe-val">'+val+'</div></div>';
}

function fecharDetalhe() {
  document.getElementById('modal-detalhe').classList.remove('open');
}

function abrirAtribuirDaModal() {
  fecharDetalhe();
  abrirAtribuir(osSelecionadaId);
}

// ── ATRIBUIR ──────────────────────────────────────────────────
async function abrirAtribuir(ixc_os_id) {
  osAtribuirId = ixc_os_id;
  document.getElementById('modal-os-num').textContent = ixc_os_id;
  document.getElementById('lista-tecnicos-modal').innerHTML = '<div style="color:var(--text3);font-size:.85rem;padding:10px">Carregando...</div>';
  document.getElementById('modal-atribuir').classList.add('open');
  try {
    var sugestoes = await api('/api/despacho/sugerir-tecnico/'+ixc_os_id);
    var html = '';
    if (!sugestoes || !sugestoes.length) {
      html = '<div style="color:var(--text3);font-size:.85rem">Nenhum tecnico disponivel</div>';
    } else {
      sugestoes.forEach(function(t, i) {
        html += '<div class="tecnico-option '+(i===0?'best':'')+'" data-id="'+t.id+'">';
        html += '<div><div style="font-weight:700;font-size:.88rem">'+(i===0?'⭐ ':'')+t.nome+'</div>';
        html += '<div style="font-size:.75rem;color:var(--text3)">'+t.distancia_km+' km &middot; '+t.os_ativas+' OS ativas</div></div>';
        html += '<button class="btn btn-p" style="font-size:.75rem" onclick="atribuirOS('+t.id+')">Atribuir</button>';
        html += '</div>';
      });
    }
    document.getElementById('lista-tecnicos-modal').innerHTML = html;
  } catch(e) {
    document.getElementById('lista-tecnicos-modal').innerHTML = '<div style="color:var(--red);font-size:.85rem">Erro ao carregar tecnicos</div>';
  }
}

async function atribuirOS(id_tecnico) {
  var dr = document.getElementById('inp-data-reservada').value;
  var drFmt = dr ? dr.replace('T',' ') : null;
  try {
    await api('/api/os/'+osAtribuirId+'/atribuir',{method:'POST',body:JSON.stringify({id_tecnico:id_tecnico,data_reservada:drFmt})});
    fecharModal();
    carregarDados();
    toast('OS atribuida com sucesso!','ok');
  } catch(e) { toast('Erro ao atribuir OS','err'); }
}

function fecharModal() { document.getElementById('modal-atribuir').classList.remove('open'); }

// ── FILTROS ───────────────────────────────────────────────────
function selecionarTipo(tipo) {
  tipoFiltro = tipo;
  renderSidebar();
  renderMapa();
}

function toggleFiltro(tipo, btn) {
  if (filtros.has(tipo)) { filtros.delete(tipo); btn.classList.remove('active'); }
  else { filtros.add(tipo); btn.classList.add('active'); }
  renderSidebar();
  renderMapa();
}

// ── HELPERS ───────────────────────────────────────────────────
function labelStatus(s) {
  var m = {pendente:'Pendente',deslocamento:'Deslocamento',agendada:'Agendada',reagendada:'Reagendada',execucao:'Execucao',finalizada:'Finalizada'};
  return m[s]||s;
}
function labelStatusFull(s) {
  var m = {pendente:'🔴 Pendente',deslocamento:'🟡 Deslocamento',agendada:'📅 Agendada',reagendada:'📅 Reagendada',execucao:'🔵 Execucao',finalizada:'✅ Finalizada'};
  return m[s]||s;
}

function toast(msg, tipo) {
  tipo = tipo||'ok';
  var t = document.createElement('div');
  t.className = 'toast '+tipo;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){ t.remove(); },300); }, 2500);
}

// ── USUARIOS ──────────────────────────────────────────────────
async function carregarUsuarios() {
  var rows = await api('/api/admin/usuarios');
  _usuarios = rows;
  var html = '';
  rows.forEach(function(u) {
    var nl = u.nivel>=99?'<b style="color:var(--accent)">Admin</b>':u.nivel>=50?'<b style="color:var(--blue)">Supervisor</b>':u.nivel>=40?'<b style="color:var(--amber)">Frota</b>':'<b style="color:var(--green)">Tecnico</b>';
    html += '<tr><td><b>'+u.nome+'</b></td><td style="color:var(--text3)">'+u.login+'</td><td>'+nl+'</td><td style="color:var(--text3)">'+(u.ixc_funcionario_id||'—')+'</td><td>'+(u.ativo?'<span style="color:var(--green)">Ativo</span>':'<span style="color:var(--red)">Inativo</span>')+'</td><td><button class="btn btn-o" style="padding:3px 8px;font-size:.75rem" onclick="editarUsuario('+u.id+')">Editar</button></td></tr>';
  });
  document.getElementById('tbody-usuarios').innerHTML = html;
}

function abrirNovoUsuario() {
  document.getElementById('modal-user-titulo').textContent='Novo Usuario';
  document.getElementById('mu-id').value='';
  document.getElementById('mu-nome').value='';
  document.getElementById('mu-login').value='';
  document.getElementById('mu-senha').value='';
  document.getElementById('mu-nivel').value='10';
  document.getElementById('mu-ixc').value='';
  document.getElementById('mu-ativo').value='1';
  document.getElementById('modal-usuario').classList.add('open');
}

function editarUsuario(id) {
  var u = _usuarios.find(function(x){ return x.id===id; });
  if (!u) return;
  document.getElementById('modal-user-titulo').textContent='Editar Usuario';
  document.getElementById('mu-id').value=u.id;
  document.getElementById('mu-nome').value=u.nome;
  document.getElementById('mu-login').value=u.login;
  document.getElementById('mu-senha').value='';
  document.getElementById('mu-nivel').value=u.nivel;
  document.getElementById('mu-ixc').value=u.ixc_funcionario_id||'';
  document.getElementById('mu-ativo').value=u.ativo;
  document.getElementById('modal-usuario').classList.add('open');
}

async function salvarUsuario() {
  var id = document.getElementById('mu-id').value;
  var data = {
    nome: document.getElementById('mu-nome').value.trim(),
    login: document.getElementById('mu-login').value.trim(),
    senha: document.getElementById('mu-senha').value,
    nivel: parseInt(document.getElementById('mu-nivel').value),
    ixc_funcionario_id: parseInt(document.getElementById('mu-ixc').value)||0,
    ativo: parseInt(document.getElementById('mu-ativo').value)
  };
  if (!data.nome||!data.login) { alert('Nome e login obrigatorios'); return; }
  var r = await api(id?'/api/admin/usuarios/'+id:'/api/admin/usuarios',{method:id?'PUT':'POST',body:JSON.stringify(data)});
  if (r.ok) { fecharModalUsuario(); carregarUsuarios(); toast('Salvo com sucesso','ok'); }
  else alert(r.detail||'Erro ao salvar');
}

function fecharModalUsuario() { document.getElementById('modal-usuario').classList.remove('open'); }

// ── FROTA ─────────────────────────────────────────────────────
var mapaFrota = null;
var veiculosCache = [];
var marcadoresFrota = {};

function iniciarMapaFrota() {
  if (mapaFrota) return;
  mapaFrota = L.map('mapa-frota').setView([-15.7942, -47.8825], 12);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
    attribution:'© OpenStreetMap', maxZoom:19
  }).addTo(mapaFrota);
}

async function carregarFrota() {
  try {
    var veiculos = await api('/api/admin/veiculos');
    var vinculos = await api('/api/admin/vinculos-hoje');
    var gps = await api('/api/gps/posicoes');
    veiculosCache = veiculos || [];
    renderVeiculos(veiculos, vinculos);
    renderVinculosHoje(vinculos);
    renderMapaFrota(gps, vinculos);
    document.getElementById('frota-total').textContent = veiculos.length;
  } catch(e) { console.log('Erro frota:', e); }
}

function renderVeiculos(veiculos, vinculos) {
  var lista = document.getElementById('lista-veiculos');
  if (!veiculos || !veiculos.length) {
    lista.innerHTML = '<div style="padding:20px;color:var(--text3);font-size:.85rem;text-align:center">Nenhum veículo.<br>Clique em Sync IXC.</div>';
    return;
  }
  var html = '';
  veiculos.forEach(function(v) {
    var vinculo = vinculos ? vinculos.find(function(vk){ return vk.id_veiculo === v.id; }) : null;
    var tecNome = vinculo ? vinculo.tecnico_nome : null;
    var emoji = {moto:'🏍️',pickup:'🛻',eletrico:'⚡',carro:'🚗'}[v.tipo] || '🚗';
    var ativo = v.ativo ? '<span style="color:var(--green);font-size:.7rem">● Ativo</span>' : '<span style="color:var(--text3);font-size:.7rem">● Inativo</span>';
    html += '<div style="padding:10px 12px;border-radius:8px;border:1px solid var(--border);margin-bottom:6px;background:var(--surf2)">';
    html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">';
    html += '<span style="font-weight:800;font-size:.9rem">'+emoji+' '+v.placa+'</span>'+ativo;
    html += '</div>';
    html += '<div style="font-size:.8rem;color:var(--text2);margin-bottom:3px">'+v.marca_modelo+(v.ano_fab?' · '+v.ano_fab:'')+(v.cor?' · '+v.cor:'')+'</div>';
    if (tecNome) {
      html += '<div style="font-size:.75rem;color:var(--accent);margin-top:4px">👤 '+tecNome+' (hoje)</div>';
    } else {
      html += '<div style="font-size:.75rem;color:var(--text3);margin-top:4px">Sem técnico hoje</div>';
    }
    html += '</div>';
  });
  lista.innerHTML = html;
}

function renderVinculosHoje(vinculos) {
  var el = document.getElementById('vinculos-hoje');
  if (!vinculos || !vinculos.length) {
    el.innerHTML = '<div style="font-size:.75rem;color:var(--text3)">Nenhum vínculo hoje</div>';
    return;
  }
  var html = '';
  vinculos.forEach(function(v) {
    var emoji = {moto:'🏍️',pickup:'🛻',eletrico:'⚡',carro:'🚗'}[v.tipo] || '🚗';
    html += '<div style="display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--border)">';
    html += '<span style="font-size:.8rem;font-weight:700;flex:1">'+v.tecnico_nome+'</span>';
    html += '<span style="font-size:.78rem;color:var(--text2)">'+emoji+' '+v.placa+'</span>';
    html += '</div>';
  });
  el.innerHTML = html;
}

function renderMapaFrota(gps, vinculos) {
  if (!mapaFrota) return;
  Object.values(marcadoresFrota).forEach(function(m){ mapaFrota.removeLayer(m); });
  marcadoresFrota = {};
  if (!gps || !gps.length) return;
  gps.forEach(function(t) {
    if (!t.lat || !t.lon) return;
    var agora = new Date();
    var regEm = t.registrado_em ? new Date(t.registrado_em) : null;
    var minParado = regEm ? Math.floor((agora - regEm) / 60000) : 999;
    var vel = parseFloat(t.velocidade) || 0;
    var cor = vel > 3 ? '#00e5a0' : (minParado >= 30 ? '#ff4d6a' : '#ffb83f');
    var emoji = vel > 3 ? '🚗' : (minParado >= 30 ? '⏱️' : '🅿️');
    var label = t.tecnico_nome ? t.tecnico_nome.split(' ')[0] : '';
    var statusTxt = vel > 3 ? 'Em movimento ('+Math.round(vel)+' km/h)' : (minParado >= 30 ? 'Parado há '+minParado+' min' : 'Parado');
    var vinculo = vinculos ? vinculos.find(function(v){ return v.id_tecnico === t.id_tecnico; }) : null;
    var placaInfo = vinculo ? ' · '+vinculo.placa : '';
    var icon = L.divIcon({
      className:'',
      html:'<div style="background:#1c2330;border:2px solid '+cor+';border-radius:8px;padding:2px 7px;font-size:11px;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.5);color:#fff;font-weight:700">'+emoji+' '+label+placaInfo+'</div>',
      iconSize:[120,26], iconAnchor:[60,13]
    });
    var m = L.marker([t.lat, t.lon], {icon: icon, zIndexOffset:1000})
      .addTo(mapaFrota)
      .bindTooltip('<b>'+t.tecnico_nome+'</b>'+placaInfo+'<br>'+statusTxt+'<br>'+(t.registrado_em||''), {direction:'top'});
    marcadoresFrota[t.id_tecnico] = m;
  });
}

async function syncVeiculos() {
  try {
    var r = await api('/api/admin/veiculos/sync', {method:'POST'});
    if (r.ok) { toast('Sincronizados: '+r.total+' veículos','ok'); carregarFrota(); }
    else toast('Erro ao sincronizar','err');
  } catch(e) { toast('Erro ao sincronizar','err'); }
}

async function abrirVincular() {
  var hoje = new Date().toLocaleDateString('pt-BR');
  document.getElementById('vincular-data').textContent = hoje;
  var tecnicos = await api('/api/admin/usuarios');
  var selTec = document.getElementById('vincular-tecnico');
  selTec.innerHTML = tecnicos.filter(function(u){ return u.nivel===10 && u.ativo; })
    .map(function(u){ return '<option value="'+u.id+'">'+u.nome+'</option>'; }).join('');
  var selVei = document.getElementById('vincular-veiculo');
  selVei.innerHTML = veiculosCache.filter(function(v){ return v.ativo; })
    .map(function(v){ return '<option value="'+v.id+'">'+v.placa+' — '+v.marca_modelo+'</option>'; }).join('');
  document.getElementById('modal-vincular').classList.add('open');
}

async function salvarVinculo() {
  var id_tecnico = parseInt(document.getElementById('vincular-tecnico').value);
  var id_veiculo = parseInt(document.getElementById('vincular-veiculo').value);
  try {
    var r = await api('/api/admin/usuarios/'+id_tecnico+'/veiculo', {method:'POST', body:JSON.stringify({id_veiculo: id_veiculo, ixc_condutor_id: 0})});
    if (r.ok) { fecharVincular(); carregarFrota(); toast('Vínculo salvo!','ok'); }
    else toast('Erro ao salvar','err');
  } catch(e) { toast('Erro ao salvar','err'); }
}

function fecharVincular() { document.getElementById('modal-vincular').classList.remove('open'); }


// ── DESPESAS ─────────────────────────────────────────────────
var _condutoresDespesa = [];
var _veiculosDespesa = [];

async function carregarDespesas() {
  var veiculo = document.getElementById('desp-fil-veiculo') ? document.getElementById('desp-fil-veiculo').value : '';
  var ini = document.getElementById('desp-fil-ini') ? document.getElementById('desp-fil-ini').value : '';
  var fim = document.getElementById('desp-fil-fim') ? document.getElementById('desp-fil-fim').value : '';
  var url = '/api/despesas?x=1';
  if (ini) url += '&data_ini='+ini;
  if (fim) url += '&data_fim='+fim;
  if (veiculo) url += '&id_veiculo='+veiculo;

  if (_veiculosDespesa.length === 0) {
    _veiculosDespesa = await api('/api/despesas/veiculos');
    var sel = document.getElementById('desp-fil-veiculo');
    if (sel) {
      sel.innerHTML = '<option value="">Todos os veiculos</option>';
      _veiculosDespesa.forEach(function(v){
        sel.innerHTML += '<option value="'+v.ixc_veiculo_id+'">'+v.placa+' -- '+v.marca_modelo+'</option>';
      });
    }
  }

  var rows = await api(url);
  if (!Array.isArray(rows)) rows = [];

  var total = rows.reduce(function(s,r){return s+(r.valor||0);},0);
  var el = document.getElementById('desp-total');
  if (el) el.textContent = rows.length+' lancamento(s) -- Total: R$ '+total.toFixed(2).replace('.',',');

  var tb = '';
  rows.forEach(function(r){
    var km = r.kilometragem ? Number(r.kilometragem).toFixed(0)+' km' : '--';
    var litros = r.quantidade_litros ? Number(r.quantidade_litros).toFixed(2)+' L' : '--';
    var badge = r.ixc_despesa_id
      ? '<span style="color:var(--green);font-size:.72rem">ok #'+r.ixc_despesa_id+'</span>'
      : '<span style="color:var(--red);font-size:.72rem">sem sync</span>';
    tb += '<tr>'
      +'<td>'+r.data+'</td>'
      +'<td style="font-size:.78rem">'+(r.placa||'--')+'</td>'
      +'<td><span style="font-size:.72rem;background:var(--surf2);padding:2px 7px;border-radius:4px">'+r.tipo+'</span></td>'
      +'<td style="font-size:.82rem">'+r.descricao+'</td>'
      +'<td style="color:var(--text3)">'+km+'</td>'
      +'<td style="color:var(--text3)">'+litros+'</td>'
      +'<td style="font-weight:700;color:var(--amber)">R$ '+Number(r.valor).toFixed(2).replace('.',',')+'</td>'
      +'<td>'+badge+'</td>'
      +'<td><button class="btn btn-o" style="padding:3px 8px;font-size:.72rem;color:var(--red)" onclick="deletarDespesa('+r.id+')">x</button></td>'
      +'</tr>';
  });
  if (!tb) tb = '<tr><td colspan="9" style="text-align:center;color:var(--text3);padding:20px">Nenhuma despesa encontrada</td></tr>';
  document.getElementById('tbody-despesas').innerHTML = tb;
}

async function abrirNovaDespesa() {
  if (_condutoresDespesa.length === 0) {
    _condutoresDespesa = await api('/api/despesas/condutores');
    var selC = document.getElementById('d-condutor');
    selC.innerHTML = '<option value="">Selecione o condutor</option>';
    _condutoresDespesa.forEach(function(c){
      selC.innerHTML += '<option value="'+c.id+'">'+c.nome+'</option>';
    });
  }
  if (_veiculosDespesa.length === 0) {
    _veiculosDespesa = await api('/api/despesas/veiculos');
  }
  var selV = document.getElementById('d-veiculo');
  selV.innerHTML = '<option value="">Selecione o veiculo</option>';
  _veiculosDespesa.forEach(function(v){
    selV.innerHTML += '<option value="'+v.ixc_veiculo_id+'">'+v.placa+' -- '+v.marca_modelo+'</option>';
  });

  document.getElementById('d-data').value = new Date().toISOString().substring(0,10);
  ['d-valor','d-km','d-litros','d-vlitro','d-obs','d-descricao'].forEach(function(id){
    var el = document.getElementById(id); if(el) el.value = '';
  });
  document.getElementById('d-tipo').value = 'Abastecimento';
  document.getElementById('d-erro').style.display = 'none';
  mostrarCamposAbast();
  document.getElementById('modal-despesa').classList.add('open');
}

function mostrarCamposAbast() {
  var tipo = document.getElementById('d-tipo') ? document.getElementById('d-tipo').value : '';
  var campos = document.getElementById('campos-abast');
  if (campos) campos.style.display = (tipo === 'Abastecimento') ? 'contents' : 'none';
}

async function salvarDespesa() {
  var erro = document.getElementById('d-erro');
  erro.style.display = 'none';
  var veiculo = document.getElementById('d-veiculo').value;
  var condutor = document.getElementById('d-condutor').value;
  var tipo = document.getElementById('d-tipo').value;
  var data = document.getElementById('d-data').value;
  var descricao = document.getElementById('d-descricao').value.trim();
  var valor = parseFloat(document.getElementById('d-valor').value);
  if (!veiculo || !condutor || !data || !descricao || isNaN(valor) || valor <= 0) {
    erro.textContent = 'Preencha veiculo, condutor, tipo, data, descricao e valor.';
    erro.style.display = 'block'; return;
  }
  var body = {
    id_veiculo: parseInt(veiculo), id_condutor: parseInt(condutor),
    tipo: tipo, descricao: descricao, valor: valor, data: data,
    kilometragem: parseFloat(document.getElementById('d-km').value) || null,
    valor_litro: parseFloat(document.getElementById('d-vlitro').value) || null,
    quantidade_litros: parseFloat(document.getElementById('d-litros').value) || null,
    observacao: document.getElementById('d-obs').value || null
  };
  var r = await api('/api/despesas', {method:'POST', body:JSON.stringify(body)});
  if (r && r.ok) {
    fecharModalDespesa();
    carregarDespesas();
    toast('Despesa salva' + (r.ixc_id ? ' e enviada ao IXC (#'+r.ixc_id+')' : ' (falha sync IXC)'), 'ok');
  } else {
    erro.textContent = (r && r.detail) ? r.detail : 'Erro ao salvar';
    erro.style.display = 'block';
  }
}

async function deletarDespesa(id) {
  if (!confirm('Deletar esta despesa? A exclusao tambem ocorre no IXC.')) return;
  var r = await api('/api/despesas/'+id, {method:'DELETE'});
  if (r && r.ok) { carregarDespesas(); toast('Despesa removida', 'ok'); }
  else toast('Erro ao deletar', 'err');
}

function fecharModalDespesa() {
  document.getElementById('modal-despesa').classList.remove('open');
}

// ── REVISOES ──────────────────────────────────────────────────
function toggleChip(el) {
  el.classList.toggle('selecionado');
  // Atualiza o input com os chips selecionados
  var selecionados = Array.from(document.querySelectorAll('.chip-item.selecionado'))
    .map(function(c){ return c.textContent.trim(); });
  var input = document.getElementById('rev-item');
  if (selecionados.length) {
    input.value = selecionados.join(', ');
  } else {
    input.value = '';
  }
}

function limparChips() {
  document.querySelectorAll('.chip-item.selecionado').forEach(function(c){ c.classList.remove('selecionado'); });
}

function marcarChipsSalvos(texto) {
  // Ao editar, marca os chips que batem com o texto salvo
  limparChips();
  if (!texto) return;
  document.querySelectorAll('.chip-item').forEach(function(chip) {
    var label = chip.textContent.trim();
    if (texto.includes(label)) chip.classList.add('selecionado');
  });
}


var diasFiltroRevisao = 15;
var _veiculosLista = [];

function mudarFiltroRevisao(dias, btn) {
  diasFiltroRevisao = dias;
  document.querySelectorAll('[id^="rbtn-"]').forEach(function(b){b.classList.remove('active');});
  if (btn) btn.classList.add('active');
  carregarRevisoes();
}

async function carregarRevisoes() {
  var lista = document.getElementById('rev-lista');
  if (lista) lista.innerHTML = '<div style="text-align:center;color:var(--text3);padding:40px">Carregando...</div>';
  try {
    var dias = diasFiltroRevisao > 0 ? diasFiltroRevisao : 3650;
    var dados = await api('/api/frota/revisoes/proximas?dias=' + dias);
    renderRevisoes(dados);
  } catch(e) {
    if (lista) lista.innerHTML = '<div style="text-align:center;color:var(--red);padding:40px">Erro ao carregar revisoes.</div>';
  }
}

function renderRevisoes(dados) {
  var stats = dados.stats || {};
  var revisoes = dados.revisoes || [];
  var el = function(id,v){ var e=document.getElementById(id); if(e) e.textContent=v; };
  el('rsc-num-vencido', stats.vencidos||0);
  el('rsc-num-urgente', stats.urgentes||0);
  el('rsc-num-aviso', stats.avisos||0);
  el('rsc-num-ok', stats.ok||0);
  el('rsc-num-total', stats.total||0);
  var lista = document.getElementById('rev-lista');
  if (!lista) return;
  if (!revisoes.length) {
    lista.innerHTML = '<div style="text-align:center;color:var(--text3);padding:60px;font-size:.9rem">Nenhuma revisao pendente.<br><span style="font-size:.8rem;display:block;margin-top:8px">Use "+ Nova Revisao" para cadastrar itens.</span></div>';
    return;
  }
  var por_veiculo = {};
  revisoes.forEach(function(r) {
    var key = r.ht_veiculo_id;
    if (!por_veiculo[key]) por_veiculo[key] = {placa:r.placa, modelo:r.marca_modelo, items:[]};
    por_veiculo[key].items.push(r);
  });
  var urgLabels = {vencido:'🚨 VENCIDO', urgente:'⚠️ Urgente', aviso:'📅 Aviso', ok:'✅ Em dia'};
  var html = '';
  Object.values(por_veiculo).forEach(function(v) {
    var temVencido = v.items.some(function(i){return i.urgencia==='vencido';});
    var temUrgente = v.items.some(function(i){return i.urgencia==='urgente';});
    var corPlaca = temVencido?'#ef4444':temUrgente?'#f59e0b':'var(--text)';
    html += '<div style="margin-bottom:24px">';
    html += '<div class="rev-grupo-titulo" style="color:'+corPlaca+'">🚗 '+v.placa+' <span style="font-weight:400;color:var(--text3);font-size:.7rem">— '+(v.modelo||'').substring(0,50)+'</span></div>';
    v.items.forEach(function(r) {
      var diasTxt = '';
      if (r.dias_restantes !== null && r.dias_restantes !== undefined) {
        if (r.dias_restantes < 0) diasTxt = '<span style="color:#ef4444;font-weight:800">Vencido ha '+Math.abs(r.dias_restantes)+' dias</span>';
        else if (r.dias_restantes === 0) diasTxt = '<span style="color:#ef4444;font-weight:800">Vence hoje!</span>';
        else diasTxt = '<span style="color:'+(r.dias_restantes<=7?'#f59e0b':r.dias_restantes<=15?'#3b82f6':'#22c55e')+';font-weight:700">Em '+r.dias_restantes+' dias</span>';
      }
      html += '<div class="rev-card '+r.urgencia+'">'
        +'<div style="display:flex;align-items:flex-start;gap:10px">'
        +'<div style="flex:1"><div style="font-weight:700;font-size:.9rem;margin-bottom:5px">'+r.item+'</div>'
        +'<div style="display:flex;gap:14px;flex-wrap:wrap;font-size:.78rem;color:var(--text3)">'
        +(r.data_prevista?'<span>📅 '+r.data_prevista+'</span>':'')
        +(r.km_previsto?'<span>🛣️ '+r.km_previsto.toLocaleString()+' km</span>':'')
        +(r.ultima_data?'<span>✔ Ultima: '+r.ultima_data+'</span>':'')
        +(r.intervalo_dias?'<span>🔁 '+r.intervalo_dias+'d</span>':'')
        +(r.intervalo_km?'<span>🔁 '+r.intervalo_km.toLocaleString()+' km</span>':'')
        +'</div>'+(r.obs?'<div style="font-size:.75rem;color:var(--text3);margin-top:4px">'+r.obs+'</div>':'')+'</div>'
        +'<div style="display:flex;flex-direction:column;gap:4px;align-items:flex-end;min-width:90px">'
        +'<span style="font-size:.72rem;font-weight:800">'+urgLabels[r.urgencia]+'</span>'
        +'<span style="font-size:.72rem">'+diasTxt+'</span></div></div>'
        +'<div style="display:flex;gap:6px;margin-top:10px;border-top:1px solid var(--border);padding-top:8px">'
        +'<button class="btn btn-o" style="font-size:.72rem;padding:3px 10px" onclick="abrirModalRealizar('+r.id+','+JSON.stringify(r.item)+')">✅ Realizada</button>'
        +'<button class="btn btn-o" style="font-size:.72rem;padding:3px 10px" onclick="editarRevisao('+r.id+')">✏️ Editar</button>'
        +'<button class="btn btn-o" style="font-size:.72rem;padding:3px 10px;color:var(--red)" onclick="excluirRevisao('+r.id+')">🗑️</button>'
        +'</div></div>';
    });
    html += '</div>';
  });
  lista.innerHTML = html;
}

async function abrirModalNovaRevisao() {
  document.getElementById('modal-rev-titulo').textContent = 'Nova Revisao';
  limparChips();
  ['rev-id','rev-item','rev-data','rev-km','rev-int-dias','rev-int-km','rev-obs'].forEach(function(id){
    document.getElementById(id).value='';
  });
  await carregarVeiculosSelect();
  document.getElementById('modal-revisao').style.display='flex';
}

async function editarRevisao(id) {
  try {
    var dados = await api('/api/frota/revisoes/proximas?dias=3650');
    var r = (dados.revisoes||[]).find(function(x){return x.id===id;});
    if (!r) { toast('Revisao nao encontrada','err'); return; }
    document.getElementById('modal-rev-titulo').textContent = 'Editar Revisao';
    document.getElementById('rev-id').value = r.id;
    await carregarVeiculosSelect(r.ht_veiculo_id);
    document.getElementById('rev-item').value = r.item||'';
    marcarChipsSalvos(r.item||'');
    document.getElementById('rev-data').value = r.data_prevista||'';
    document.getElementById('rev-km').value = r.km_previsto||'';
    document.getElementById('rev-int-dias').value = r.intervalo_dias||'';
    document.getElementById('rev-int-km').value = r.intervalo_km||'';
    document.getElementById('rev-obs').value = r.obs||'';
    document.getElementById('modal-revisao').style.display='flex';
  } catch(e) { toast('Erro ao carregar','err'); }
}

async function carregarVeiculosSelect(selecionado) {
  if (!_veiculosLista.length) {
    try { _veiculosLista = await api('/api/frota/veiculos'); } catch(e) { _veiculosLista=[]; }
  }
  var sel = document.getElementById('rev-veiculo');
  if (!sel) return;
  sel.innerHTML = '<option value="">Selecione...</option>'
    + _veiculosLista.map(function(v){
        return '<option value="'+v.id+'"'+(selecionado==v.id?' selected':'')+'>'+v.placa+' - '+(v.marca_modelo||'').substring(0,35)+'</option>';
      }).join('');
}

async function salvarRevisao() {
  var id = document.getElementById('rev-id').value;
  var veiculo = document.getElementById('rev-veiculo').value;
  var item = document.getElementById('rev-item').value.trim();
  if (!veiculo) { toast('Selecione o veiculo','err'); return; }
  if (!item) { toast('Informe o item de revisao','err'); return; }
  var data = {
    ht_veiculo_id: parseInt(veiculo), item: item,
    data_prevista: document.getElementById('rev-data').value||null,
    km_previsto: parseInt(document.getElementById('rev-km').value)||null,
    intervalo_dias: parseInt(document.getElementById('rev-int-dias').value)||0,
    intervalo_km: parseInt(document.getElementById('rev-int-km').value)||0,
    obs: document.getElementById('rev-obs').value.trim()
  };
  try {
    if (id) await api('/api/frota/revisoes/'+id,{method:'PUT',body:JSON.stringify(data)});
    else await api('/api/frota/revisoes',{method:'POST',body:JSON.stringify(data)});
    fecharModalRevisao(); carregarRevisoes(); toast('Revisao salva!','ok');
  } catch(e) { toast('Erro ao salvar','err'); }
}

function fecharModalRevisao() { document.getElementById('modal-revisao').style.display='none'; }

function abrirModalRealizar(id, item) {
  document.getElementById('realizar-id').value = id;
  document.getElementById('realizar-info').textContent = item;
  document.getElementById('realizar-data').value = new Date().toISOString().substring(0,10);
  document.getElementById('realizar-km').value = '';
  document.getElementById('realizar-obs').value = '';
  document.getElementById('modal-realizar').style.display='flex';
}

function fecharModalRealizar() { document.getElementById('modal-realizar').style.display='none'; }

async function confirmarRealizacao() {
  var id = document.getElementById('realizar-id').value;
  var dataR = document.getElementById('realizar-data').value;
  if (!dataR) { toast('Informe a data','err'); return; }
  var data = {
    data_realizada: dataR,
    km_realizado: parseInt(document.getElementById('realizar-km').value)||null,
    obs: document.getElementById('realizar-obs').value.trim()
  };
  try {
    var r = await api('/api/frota/revisoes/'+id+'/realizar',{method:'POST',body:JSON.stringify(data)});
    fecharModalRealizar(); carregarRevisoes();
    toast('Revisao registrada!'+(r.proxima_data?' Proxima: '+r.proxima_data:''),'ok');
  } catch(e) { toast('Erro ao registrar','err'); }
}

async function excluirRevisao(id) {
  if (!confirm('Remover este item?')) return;
  try {
    await api('/api/frota/revisoes/'+id,{method:'DELETE'});
    carregarRevisoes(); toast('Removido','ok');
  } catch(e) { toast('Erro ao remover','err'); }
}

// ── INIT ──────────────────────────────────────────────────────
(function(){
  var t = localStorage.getItem('ht_hub_token') || localStorage.getItem('ht_despacho_token');
  var u = localStorage.getItem('ht_hub_usuario') || localStorage.getItem('ht_despacho_usuario');
  if (t && u) {
    try { iniciarApp(JSON.parse(u)); }
    catch(e) { document.getElementById('P-LOGIN').style.display = 'flex'; }
  } else {
    document.getElementById('P-LOGIN').style.display = 'flex';
  }
})();
</script>

<!-- MODAL DESPESA -->
<div class="modal-bg" id="modal-despesa">
  <div class="modal" style="max-width:520px">
    <div class="modal-title">
      <span>Nova Despesa</span>
      <button onclick="fecharModalDespesa()" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:1.1rem">x</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      <div class="field" style="grid-column:1/-1">
        <label>Veiculo</label>
        <select id="d-veiculo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
          <option value="">Selecione o veiculo</option>
        </select>
      </div>
      <div class="field" style="grid-column:1/-1">
        <label>Condutor</label>
        <select id="d-condutor" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
          <option value="">Selecione o condutor</option>
        </select>
      </div>
      <div class="field">
        <label>Tipo</label>
        <select id="d-tipo" onchange="mostrarCamposAbast()" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
          <option value="Abastecimento">Abastecimento</option>
          <option value="Manutencao">Manutencao</option>
          <option value="Pedagio">Pedagio</option>
          <option value="Multa">Multa</option>
          <option value="Lavagem">Lavagem</option>
          <option value="Estacionamento">Estacionamento</option>
          <option value="Outros">Outros</option>
        </select>
      </div>
      <div class="field">
        <label>Data</label>
        <input type="date" id="d-data" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
      </div>
      <div class="field" style="grid-column:1/-1">
        <label>Descricao</label>
        <input type="text" id="d-descricao" placeholder="Ex: Abastecimento posto BR" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
      </div>
      <div class="field">
        <label>Valor (R$)</label>
        <input type="number" id="d-valor" step="0.01" min="0" placeholder="0,00" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
      </div>
      <div class="field">
        <label>Quilometragem</label>
        <input type="number" id="d-km" step="1" min="0" placeholder="KM atual" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
      </div>
      <div id="campos-abast" style="display:contents">
        <div class="field">
          <label>Qtd Litros</label>
          <input type="number" id="d-litros" step="0.01" min="0" placeholder="0,00" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
        </div>
        <div class="field">
          <label>Valor/Litro (R$)</label>
          <input type="number" id="d-vlitro" step="0.001" min="0" placeholder="0,000" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
        </div>
      </div>
      <div class="field" style="grid-column:1/-1">
        <label>Observacao</label>
        <input type="text" id="d-obs" placeholder="Observacao opcional" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
      </div>
    </div>
    <div id="d-erro" style="color:var(--red);font-size:.82rem;margin-bottom:8px;display:none"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px">
      <button class="btn btn-o" onclick="fecharModalDespesa()">Cancelar</button>
      <button class="btn btn-p" onclick="salvarDespesa()">Salvar e Enviar IXC</button>
    </div>
  </div>
</div>

<!-- MODAL CHECKLIST -->
<div class="modal-bg" id="modal-checklist">
  <div class="modal" style="max-width:560px;max-height:90vh;overflow-y:auto">
    <div class="modal-title">
      <span id="chk-modal-titulo">Checklist de Saida</span>
      <button onclick="fecharChecklist()" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:1.1rem">x</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
      <div class="field" style="grid-column:1/-1">
        <label>Veiculo</label>
        <select id="chk-m-veiculo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
          <option value="">Selecione...</option>
        </select>
      </div>
      <div class="field">
        <label>Tipo</label>
        <select id="chk-m-tipo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
          <option value="saida">Saida</option>
          <option value="retorno">Retorno</option>
        </select>
      </div>
      <div class="field">
        <label>KM atual</label>
        <input type="number" id="chk-m-km" placeholder="KM do veiculo" style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px">
      </div>
    </div>
    <div style="font-size:.82rem;font-weight:700;color:var(--text3);margin-bottom:8px;text-transform:uppercase;letter-spacing:.05em">Itens de Inspecao</div>
    <div id="chk-m-itens" style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px"></div>
    <div class="field">
      <label>Observacoes gerais</label>
      <textarea id="chk-m-obs" rows="2" placeholder="Observacoes opcionais..." style="width:100%;background:var(--surf2);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:8px 10px;outline:none;margin-top:5px;resize:vertical;font-family:inherit;font-size:.85rem"></textarea>
    </div>
    <div id="chk-erro" style="color:var(--red);font-size:.82rem;margin-bottom:8px;display:none"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px">
      <button class="btn btn-o" onclick="fecharChecklist()">Cancelar</button>
      <button class="btn btn-p" onclick="salvarChecklist()">Salvar Checklist</button>
    </div>
  </div>
</div>
</body>
</html>
